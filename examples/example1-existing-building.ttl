@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix edintcee: <http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/> .
@prefix edintceekos-bu: <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/building-use/> .
@prefix edintceekos-es: <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/energy-source/> .
@prefix edintceekos-cz: <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/climatic-zone/> .
@prefix ex: <http://ejemplo.org/cee/> .

# ---------------------------------------------------------------------------
# EXAMPLE 1: Existing building certificate
# Residential block in Madrid, built 2005, rating D
# The building points to the certificate from outside this ontology:
#   <http://ejemplo.org/edificios/block_mayor10>
#       ex:hasEnergyCertificate ex:cert_2024_M12345 .
# ---------------------------------------------------------------------------

# --- Calculation Procedure ---

ex:proc_CEP a edintcee:CalculationProcedure ;
    edintcee:procedureName "CEP" ;
    edintcee:procedureVersion "7.0" ;
    edintcee:procedureType "general" .

# --- Competent Technician ---

ex:tech_mlopez a edintcee:CompetentTechnician ;
    edintcee:technicianName "María López García" ;
    edintcee:technicianNIF "23456789B" ;
    edintcee:technicianQualification "Arquitecta" ;
    edintcee:technicianRegistrationCCAA "Comunidad de Madrid" ;
    edintcee:technicianPublicAuthorization "true"^^xsd:boolean .

# --- User Recommendations ---

ex:userrec_2024_M12345 a edintcee:UserRecommendations ;
    edintcee:userRecommendationsDelivered "true"^^xsd:boolean ;
    edintcee:userRecommendationsDeliveryDate "2024-05-20"^^xsd:date ;
    edintcee:userRecommendationsRecipient "Owner" .

# --- Energy Certificate ---

ex:cert_2024_M12345 a edintcee:ExistingBuildingCertificate ;
    edintcee:hasRating              ex:rating_2024_M12345 ;
    edintcee:issuedBy               ex:tech_mlopez ;
    edintcee:hasLabel               ex:label_2024_M12345 ;
    edintcee:usesProcedure          ex:proc_CEP ;
    edintcee:hasUserRecommendations ex:userrec_2024_M12345 ;
    edintcee:predecessorCertificate ex:cert_2016_M12345 ;

    # Certificate metadata
    edintcee:certificateNumber      "M-2024-012345" ;
    edintcee:issueDate              "2024-05-20"^^xsd:date ;
    edintcee:visitDate              "2024-05-15"^^xsd:date ;
    edintcee:registrationDate       "2024-05-28"^^xsd:date ;
    edintcee:validUntil             "2034-05-20"^^xsd:date ;
    edintcee:visitDescription       "Visita in situ: comprobación de cerramientos de fachada, cubierta, carpintería exterior. Verificación de caldera mural de gas natural en vivienda tipo." ;
    edintcee:applicableRegulation   "CTE DB-HE (2006), RITE (2007)" ;
    edintcee:registrationCCAA       "Comunidad de Madrid" ;

    # Observed building data
    edintcee:observedCadastralRef       "2807901VK4717F0001WX" ;
    edintcee:observedAddress            "Calle Mayor 10" ;
    edintcee:observedMunicipality       "Madrid" ;
    edintcee:observedProvince           "Madrid" ;
    edintcee:observedUsefulSurface      "4820.0"^^xsd:decimal ;
    edintcee:observedConstructionYear   "2005"^^xsd:gYear ;
    edintcee:observedBuildingUse        edintceekos-bu:Residential ;
    edintcee:observedClimaticZone       edintceekos-cz:D3 ;
    edintcee:observedHeritageProtection "false"^^xsd:boolean ;
    edintcee:observedBuildingType       "existing" ;
    edintcee:observedIsBuildingPart     "false"^^xsd:boolean ;

    # Envelope
    edintcee:envelopeDescription        "Fachada de ladrillo cara vista con cámara de aire de 5 cm sin aislar. Cubierta plana transitable. Carpintería aluminio RPT, doble acristalamiento (6/12/6)." ;
    edintcee:globalHeatTransferCoeff    "1.92"^^xsd:decimal ;
    edintcee:windowAreaRatio            "28.0"^^xsd:decimal ;

    # Systems
    edintcee:hasHeatingSystem           "true"^^xsd:boolean ;
    edintcee:heatingSystemType          "Caldera mural condensación gas natural, radiadores" ;
    edintcee:heatingEnergySource        edintceekos-es:NaturalGas ;
    edintcee:heatingEfficiency          "0.92"^^xsd:decimal ;
    edintcee:hasCoolingSystem           "false"^^xsd:boolean ;
    edintcee:hasDHWSystem               "true"^^xsd:boolean ;
    edintcee:dhwSystemType              "Caldera mural gas natural, acumulador 80L" ;
    edintcee:dhwEnergySource            edintceekos-es:NaturalGas ;
    edintcee:hasRenewableGeneration     "false"^^xsd:boolean ;
    edintcee:hasAutomationSystem        "false"^^xsd:boolean ;
    edintcee:hasMechanicalVentilation   "false"^^xsd:boolean ;
    edintcee:hasHeatRecovery            "false"^^xsd:boolean ;

    # Improvement recommendations
    edintcee:hasRecommendation          ex:rec_2024_M12345_1 ;
    edintcee:hasRecommendation          ex:rec_2024_M12345_2 ;
    edintcee:hasRecommendation          ex:rec_2024_M12345_3 .

# --- Energy Rating ---

ex:rating_2024_M12345 a edintcee:EnergyRating ;
    edintcee:ratingLetter              "D" ;
    edintcee:primaryEnergyTotal        "152.4"^^xsd:decimal ;
    edintcee:primaryEnergyNonRenewable "112.8"^^xsd:decimal ;
    edintcee:primaryEnergyRenewable    "39.6"^^xsd:decimal ;
    edintcee:co2Emissions              "34.2"^^xsd:decimal ;
    edintcee:heatingDemand             "52.1"^^xsd:decimal ;
    edintcee:coolingDemand             "16.8"^^xsd:decimal ;
    edintcee:dhwDemand                 "18.3"^^xsd:decimal ;
    edintcee:heatingConsumption        "56.7"^^xsd:decimal ;
    edintcee:coolingConsumption        "19.4"^^xsd:decimal ;
    edintcee:dhwConsumption            "23.1"^^xsd:decimal ;
    edintcee:lightingConsumption       "5.2"^^xsd:decimal ;
    edintcee:dataBasis                 "calculated" .

# --- Energy Label ---

ex:label_2024_M12345 a edintcee:EnergyLabel ;
    edintcee:labelRatingLetter "D" ;
    edintcee:labelScope        "existingBuilding" .

# --- Improvement Recommendations ---

ex:rec_2024_M12345_1 a edintcee:ImprovementRecommendation ;
    edintcee:recommendationType       "installation" ;
    edintcee:recommendationDescription "Sustituir calderas individuales por sistema centralizado de aerotermia con bomba de calor aire-agua." ;
    edintcee:estimatedSavingPct       "38.0"^^xsd:decimal ;
    edintcee:estimatedSavingKwh       "43200"^^xsd:decimal ;
    edintcee:paybackPeriod            "9.5"^^xsd:decimal ;
    edintcee:estimatedCost            "185000"^^xsd:decimal ;
    edintcee:priority                 1 ;
    edintcee:improvedRatingLetter     "B" ;
    edintcee:comfortHealthBenefit     "Mayor confort térmico en invierno y posibilidad de refrigeración en verano." .

ex:rec_2024_M12345_2 a edintcee:ImprovementRecommendation ;
    edintcee:recommendationType       "envelope" ;
    edintcee:recommendationDescription "Aislamiento exterior SATE 8 cm lana de roca. Cubierta 10 cm poliuretano proyectado." ;
    edintcee:estimatedSavingPct       "25.0"^^xsd:decimal ;
    edintcee:estimatedSavingKwh       "28400"^^xsd:decimal ;
    edintcee:paybackPeriod            "14.0"^^xsd:decimal ;
    edintcee:estimatedCost            "210000"^^xsd:decimal ;
    edintcee:priority                 2 ;
    edintcee:improvedRatingLetter     "B" .

ex:rec_2024_M12345_3 a edintcee:ImprovementRecommendation ;
    edintcee:recommendationType       "automation" ;
    edintcee:recommendationDescription "Sistema de control centralizado con termostatos programables y válvulas termostáticas." ;
    edintcee:estimatedSavingPct       "8.0"^^xsd:decimal ;
    edintcee:estimatedSavingKwh       "9100"^^xsd:decimal ;
    edintcee:paybackPeriod            "3.5"^^xsd:decimal ;
    edintcee:estimatedCost            "18000"^^xsd:decimal ;
    edintcee:priority                 3 ;
    edintcee:improvedRatingLetter     "C" .

# --- Predecessor Certificate ---

ex:cert_2016_M12345 a edintcee:ExistingBuildingCertificate ;
    edintcee:hasRating        ex:rating_2016_M12345 ;
    edintcee:issuedBy         ex:tech_jperez ;
    edintcee:usesProcedure    ex:proc_CEP_old ;
    edintcee:hasUserRecommendations ex:userrec_2016_M12345 ;
    edintcee:certificateNumber "M-2016-007890" ;
    edintcee:issueDate        "2016-09-12"^^xsd:date ;
    edintcee:validUntil       "2026-09-12"^^xsd:date ;
    edintcee:observedCadastralRef "2807901VK4717F0001WX" ;
    edintcee:observedBuildingType "existing" .

ex:rating_2016_M12345 a edintcee:EnergyRating ;
    edintcee:ratingLetter              "E" ;
    edintcee:primaryEnergyNonRenewable "148.5"^^xsd:decimal ;
    edintcee:co2Emissions              "45.1"^^xsd:decimal .

ex:tech_jperez a edintcee:CompetentTechnician ;
    edintcee:technicianName "Juan Pérez Martínez" ;
    edintcee:technicianNIF "34567890C" ;
    edintcee:technicianQualification "Arquitecto técnico" ;
    edintcee:technicianRegistrationCCAA "Comunidad de Madrid" .

ex:proc_CEP_old a edintcee:CalculationProcedure ;
    edintcee:procedureName "CEP" ;
    edintcee:procedureVersion "5.2" ;
    edintcee:procedureType "general" .

ex:userrec_2016_M12345 a edintcee:UserRecommendations ;
    edintcee:userRecommendationsDelivered "true"^^xsd:boolean .
