    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://qudt.org/schema/qudt/QuantityValue -->

    <owl:Class rdf:about="http://qudt.org/schema/qudt/QuantityValue">
        <rdfs:comment xml:lang="en">Numeric value with explicit unit of measure (qudt:numericValue + qudt:hasUnit). Allows representing physical quantities such as energy (kWh/m²·year), emissions (kgCO2/m²·year), power (kW), area (m²), percentage, etc.</rdfs:comment>
        <rdfs:comment xml:lang="es">Valor numérico con unidad de medida explícita (qudt:numericValue + qudt:hasUnit). Permite representar magnitudes físicas como energía (kWh/m²·año), emisiones (kgCO2/m²·año), potencia (kW), superficie (m²), porcentaje, etc.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://qudt.org/schema/qudt/"/>
        <rdfs:label xml:lang="en">Quantity value</rdfs:label>
        <rdfs:label xml:lang="es">Valor de cantidad</rdfs:label>
    </owl:Class>
    


    <!-- http://schema.org/PostalAddress -->

    <owl:Class rdf:about="http://schema.org/PostalAddress">
        <rdfs:comment xml:lang="es">Dirección postal según schema.org.</rdfs:comment>
        <rdfs:comment xml:lang="en">Postal address according to schema.org.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://schema.org/"/>
        <rdfs:label xml:lang="es">Dirección postal (schema)</rdfs:label>
        <rdfs:label xml:lang="en">Postal address (schema)</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty -->

    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty">
        <rdfs:comment xml:lang="en">Cadastral unit that identifies a property (parcel, construction or functional unit) in the cadastre. Allows access to the cadastral reference, address, construction year, surface area and geometry.</rdfs:comment>
        <rdfs:comment xml:lang="es">Unidad catastral que identifica un inmueble (parcela, construcción o unidad funcional) en el catastro. Permite acceder a la referencia catastral, dirección, año de construcción, superficie y geometría.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/"/>
        <rdfs:label xml:lang="en">Cadastral property</rdfs:label>
        <rdfs:label xml:lang="es">Inmueble catastral</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Autonomia -->

    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Autonomia">
        <rdfs:comment xml:lang="en">Autonomous Community or Autonomous City in the Spanish territory.</rdfs:comment>
        <rdfs:comment xml:lang="es">Comunidad Autónoma o Ciudad Autónoma del territorio español.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio"/>
        <rdfs:label xml:lang="en">Autonomous community</rdfs:label>
        <rdfs:label xml:lang="es">Autonomía</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/CalculationProcedure -->

    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/CalculationProcedure">
        <rdfs:comment xml:lang="es">Procedimiento reconocido (general o simplificado) inscrito en el Registro general de documentos reconocidos, utilizado para obtener la calificación de eficiencia energética (Art. 4.2.a, Art. 5).</rdfs:comment>
        <rdfs:comment xml:lang="en">Recognised procedure (general or simplified) registered in the general registry of recognised documents, used to obtain the energy performance rating (Art. 4.2.a, Art. 5).</rdfs:comment>
        <rdfs:label xml:lang="en">Calculation procedure</rdfs:label>
        <rdfs:label xml:lang="es">Procedimiento de cálculo</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/CompetentTechnician -->

    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/CompetentTechnician">
        <rdfs:comment xml:lang="en">Technician qualified to carry out energy performance certification of buildings (Art. 4 bis).</rdfs:comment>
        <rdfs:comment xml:lang="es">Técnico habilitado para realizar la certificación de eficiencia energética de edificios (Art. 4 bis).</rdfs:comment>
        <rdfs:label xml:lang="en">Competent technician</rdfs:label>
        <rdfs:label xml:lang="es">Técnico competente</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyCertificate -->

    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyCertificate">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/hasUserRecommendations"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/UserRecommendations"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/certificateType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/hasRating"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyRating"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/issuedBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/CompetentTechnician"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/usesProcedure"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/CalculationProcedure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/issueDate"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/validUntil"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Documentación suscrita por un técnico competente que contiene la calificación de eficiencia energética de un edificio o parte del mismo, sus características energéticas y recomendaciones de mejora (Art. 2.e-g, RD 390/2021).</rdfs:comment>
        <rdfs:comment xml:lang="en">Documentation signed by a competent technician containing the energy performance rating of a building or part thereof, its energy characteristics and improvement recommendations (Art. 2.e-g, RD 390/2021).</rdfs:comment>
        <rdfs:label xml:lang="es">Certificado de eficiencia energética</rdfs:label>
        <rdfs:label xml:lang="en">Energy performance certificate</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyLabel -->

    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyLabel">
        <rdfs:comment xml:lang="en">Distinctive mark associated with a registered certificate that publicly attests to the energy rating obtained (Art. 2.ñ, Art. 15).</rdfs:comment>
        <rdfs:comment xml:lang="es">Distintivo asociado a un certificado registrado que acredita públicamente la calificación energética obtenida (Art. 2.ñ, Art. 15).</rdfs:comment>
        <rdfs:label xml:lang="en">Energy label</rdfs:label>
        <rdfs:label xml:lang="es">Etiqueta de eficiencia energética</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyRating -->

    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyRating">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/co2Emissions"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/primaryEnergyNonRenewable"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/ratingLetter"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/ratingScaleVersion"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Expresión de la eficiencia energética de un edificio mediante indicadores numéricos de consumo y emisiones, resumida en una letra de la escala A-G (Art. 2.a).</rdfs:comment>
        <rdfs:comment xml:lang="en">Expression of the energy efficiency of a building through numerical consumption and emission indicators, summarised as a letter on the A-G scale (Art. 2.a).</rdfs:comment>
        <rdfs:label xml:lang="es">Calificación energética</rdfs:label>
        <rdfs:label xml:lang="en">Energy rating</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/ImprovementRecommendation -->

    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/ImprovementRecommendation">
        <rdfs:comment xml:lang="es">Intervención técnicamente viable para la mejora de los niveles óptimos o rentables de la eficiencia energética, incluyendo estimación de costes y plazos de recuperación (Art. 8.2.f).</rdfs:comment>
        <rdfs:comment xml:lang="en">Technically viable intervention for improving optimal or cost-effective energy efficiency levels, including cost estimates and payback periods (Art. 8.2.f).</rdfs:comment>
        <rdfs:label xml:lang="en">Improvement recommendation</rdfs:label>
        <rdfs:label xml:lang="es">Recomendación de mejora</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/UserRecommendations -->

    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/UserRecommendations">
        <rdfs:comment xml:lang="en">Document with recommendations for the building user/tenant on how to use the building and its systems to achieve optimal energy efficiency (Art. 8.1.f).</rdfs:comment>
        <rdfs:comment xml:lang="es">Documento con recomendaciones para el usuario/arrendatario del edificio sobre cómo utilizar el edificio y sus sistemas para lograr la máxima eficiencia energética (Art. 8.1.f).</rdfs:comment>
        <rdfs:label xml:lang="es">Recomendaciones de uso para el usuario</rdfs:label>
        <rdfs:label xml:lang="en">User recommendations</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal -->

    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal">
        <rdfs:comment xml:lang="es">Dirección postal en España. Especialización de schema:PostalAddress, vcard:Address y locn:Address. Permite representar una dirección con propiedades como schema:streetAddress, schema:addressLocality, schema:addressRegion y schema:postalCode.</rdfs:comment>
        <rdfs:comment xml:lang="en">Postal address in Spain. Specialisation of schema:PostalAddress, vcard:Address and locn:Address. Allows representing an address with properties like schema:streetAddress, schema:addressLocality, schema:addressRegion and schema:postalCode.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal"/>
        <rdfs:label xml:lang="es">Dirección postal</rdfs:label>
        <rdfs:label xml:lang="en">Postal address</rdfs:label>
    </owl:Class>
    


