    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/certificateType -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/certificateType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyCertificate"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/CertificateType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Tipo de certificado de eficiencia energética según el vocabulario controlado de tipos de certificado: proyecto, obra terminada o edificio existente (Art. 2.b-g, Art. 9-10, Art. 15.2 RD 390/2021).</rdfs:comment>
        <rdfs:comment xml:lang="en">Type of energy performance certificate according to the certificate-type controlled vocabulary: project, completed work or existing building (Art. 2.b-g, Art. 9-10, Art. 15.2 RD 390/2021).</rdfs:comment>
        <rdfs:label xml:lang="en">certificate type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de certificado</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/co2Emissions -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/co2Emissions">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyRating"/>
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment xml:lang="en">CO2 emissions. Expressed as qudt:QuantityValue, typically in kgCO2/m²·year.</rdfs:comment>
        <rdfs:comment xml:lang="es">Emisiones de CO2. Se expresa como qudt:QuantityValue, típicamente en kgCO2/m²·año.</rdfs:comment>
        <rdfs:label xml:lang="en">CO2 emissions</rdfs:label>
        <rdfs:label xml:lang="es">emisiones de CO2</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/coolingConsumption -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/coolingConsumption">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyRating"/>
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment xml:lang="es">Consumo de refrigeración. Se expresa como qudt:QuantityValue, típicamente en kWh/m²·año.</rdfs:comment>
        <rdfs:comment xml:lang="en">Cooling consumption. Expressed as qudt:QuantityValue, typically in kWh/m²·year.</rdfs:comment>
        <rdfs:label xml:lang="es">consumo de refrigeración</rdfs:label>
        <rdfs:label xml:lang="en">cooling consumption</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/coolingDemand -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/coolingDemand">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyRating"/>
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment xml:lang="en">Cooling demand. Expressed as qudt:QuantityValue, typically in kWh/m²·year.</rdfs:comment>
        <rdfs:comment xml:lang="es">Demanda de refrigeración. Se expresa como qudt:QuantityValue, típicamente en kWh/m²·año.</rdfs:comment>
        <rdfs:label xml:lang="en">cooling demand</rdfs:label>
        <rdfs:label xml:lang="es">demanda de refrigeración</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/coolingEfficiency -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/coolingEfficiency">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyCertificate"/>
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment xml:lang="es">Rendimiento estacional del sistema de refrigeración. Se expresa como qudt:QuantityValue.</rdfs:comment>
        <rdfs:comment xml:lang="en">Seasonal efficiency of the cooling system. Expressed as qudt:QuantityValue.</rdfs:comment>
        <rdfs:label xml:lang="es">rendimiento estacional refrigeración</rdfs:label>
        <rdfs:label xml:lang="en">seasonal cooling efficiency</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/coolingEnergySource -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/coolingEnergySource">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyCertificate"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/EnergySource"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Energy source of the cooling system according to the energy-source controlled vocabulary.</rdfs:comment>
        <rdfs:comment xml:lang="es">Fuente de energía del sistema de refrigeración según el vocabulario controlado de fuentes de energía.</rdfs:comment>
        <rdfs:label xml:lang="en">cooling energy source</rdfs:label>
        <rdfs:label xml:lang="es">fuente energética de refrigeración</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/dataBasis -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/dataBasis">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyRating"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/DataBasis"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Indica si los indicadores se basan en datos medidos, calculados o mixtos, según el vocabulario controlado de tipos de base de datos (Art. 6.7).</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether indicators are based on measured, calculated or mixed data, according to the data-basis controlled vocabulary (Art. 6.7).</rdfs:comment>
        <rdfs:label xml:lang="es">base de datos</rdfs:label>
        <rdfs:label xml:lang="en">data basis</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/dhwConsumption -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/dhwConsumption">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyRating"/>
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment xml:lang="es">Consumo de agua caliente sanitaria. Se expresa como qudt:QuantityValue, típicamente en kWh/m²·año.</rdfs:comment>
        <rdfs:comment xml:lang="en">Domestic hot water consumption. Expressed as qudt:QuantityValue, typically in kWh/m²·year.</rdfs:comment>
        <rdfs:label xml:lang="en">DHW consumption</rdfs:label>
        <rdfs:label xml:lang="es">consumo de ACS</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/dhwDemand -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/dhwDemand">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyRating"/>
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment xml:lang="es">Demanda de agua caliente sanitaria. Se expresa como qudt:QuantityValue, típicamente en kWh/m²·año.</rdfs:comment>
        <rdfs:comment xml:lang="en">Domestic hot water demand. Expressed as qudt:QuantityValue, typically in kWh/m²·year.</rdfs:comment>
        <rdfs:label xml:lang="en">DHW demand</rdfs:label>
        <rdfs:label xml:lang="es">demanda de ACS</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/dhwEnergySource -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/dhwEnergySource">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyCertificate"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/EnergySource"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Energy source of the domestic hot water system according to the energy-source controlled vocabulary.</rdfs:comment>
        <rdfs:comment xml:lang="es">Fuente de energía del sistema de agua caliente sanitaria según el vocabulario controlado de fuentes de energía.</rdfs:comment>
        <rdfs:label xml:lang="en">DHW energy source</rdfs:label>
        <rdfs:label xml:lang="es">fuente energética de ACS</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/envelopeArea -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/envelopeArea">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyCertificate"/>
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment xml:lang="es">Superficie de la envolvente térmica en contacto con el exterior. Se expresa como qudt:QuantityValue (qudt:numericValue + qudt:hasUnit), típicamente en m².</rdfs:comment>
        <rdfs:comment xml:lang="en">Surface area of the thermal envelope in contact with the exterior. Expressed as qudt:QuantityValue (qudt:numericValue + qudt:hasUnit), typically in m².</rdfs:comment>
        <rdfs:label xml:lang="en">envelope area</rdfs:label>
        <rdfs:label xml:lang="es">superficie de envolvente</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/estimatedCost -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/estimatedCost">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/ImprovementRecommendation"/>
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment xml:lang="es">Coste estimado de la intervención. Se expresa como qudt:QuantityValue, típicamente en euros.</rdfs:comment>
        <rdfs:comment xml:lang="en">Estimated cost of the intervention. Expressed as qudt:QuantityValue, typically in euros.</rdfs:comment>
        <rdfs:label xml:lang="es">coste estimado</rdfs:label>
        <rdfs:label xml:lang="en">estimated cost</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/estimatedSavingKwh -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/estimatedSavingKwh">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/ImprovementRecommendation"/>
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment xml:lang="es">Ahorro estimado en energía. Se expresa como qudt:QuantityValue, típicamente en kWh/año.</rdfs:comment>
        <rdfs:comment xml:lang="en">Estimated energy saving. Expressed as qudt:QuantityValue, typically in kWh/year.</rdfs:comment>
        <rdfs:label xml:lang="es">ahorro estimado en energía</rdfs:label>
        <rdfs:label xml:lang="en">estimated saving in energy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/estimatedSavingPct -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/estimatedSavingPct">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/ImprovementRecommendation"/>
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment xml:lang="es">Ahorro estimado porcentual. Se expresa como qudt:QuantityValue, típicamente en porcentaje.</rdfs:comment>
        <rdfs:comment xml:lang="en">Estimated percentage saving. Expressed as qudt:QuantityValue, typically in percent.</rdfs:comment>
        <rdfs:label xml:lang="es">ahorro estimado</rdfs:label>
        <rdfs:label xml:lang="en">estimated saving</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/globalHeatTransferCoeff -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/globalHeatTransferCoeff">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyCertificate"/>
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment xml:lang="es">Coeficiente global de transmitancia térmica U de la envolvente. Se expresa como qudt:QuantityValue, típicamente en W/m²·K.</rdfs:comment>
        <rdfs:comment xml:lang="en">Global thermal transmittance coefficient U of the envelope. Expressed as qudt:QuantityValue, typically in W/m²·K.</rdfs:comment>
        <rdfs:label xml:lang="es">coeficiente global de transmitancia</rdfs:label>
        <rdfs:label xml:lang="en">global heat transfer coefficient</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/hasLabel -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/hasLabel">
        <owl:inverseOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/labelFor"/>
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyCertificate"/>
