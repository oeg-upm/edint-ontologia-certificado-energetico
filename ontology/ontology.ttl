# DATATYPE PROPERTIES — CalculationProcedure
# =============================================================================

edintcee:procedureName a owl:DatatypeProperty ;
    rdfs:label "nombre del procedimiento"@es ;
    rdfs:label "procedure name"@en ;
    rdfs:domain edintcee:CalculationProcedure ;
    rdfs:range xsd:string .

edintcee:procedureVersion a owl:DatatypeProperty ;
    rdfs:label "versión del procedimiento"@es ;
    rdfs:label "procedure version"@en ;
    rdfs:domain edintcee:CalculationProcedure ;
    rdfs:range xsd:string .

edintcee:procedureType a owl:ObjectProperty ;
    rdfs:label "tipo de procedimiento"@es ;
    rdfs:label "procedure type"@en ;
    rdfs:domain edintcee:CalculationProcedure ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:ProcedureType
            ]
        )
    ] ;
