    rdfs:label "measured cooling consumption"@en ;
    rdfs:domain edintcee:EnergyRating ;
    rdfs:range qudt:QuantityValue ;
    rdfs:comment "Consumo medido de refrigeración. Se expresa como qudt:QuantityValue, típicamente en kWh/m²·año."@es ;
    rdfs:comment "Measured cooling consumption. Expressed as qudt:QuantityValue, typically in kWh/m²·year."@en .

edintcee:measuredDHWConsumption a owl:ObjectProperty ;
    rdfs:label "consumo medido de ACS"@es ;
    rdfs:label "measured DHW consumption"@en ;
    rdfs:domain edintcee:EnergyRating ;
    rdfs:range qudt:QuantityValue ;
