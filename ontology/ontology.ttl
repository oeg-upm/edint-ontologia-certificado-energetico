@prefix edintcee: <http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix edintceekos-bu: <http://vocab.linkeddata.es/datosabiertos/kos/edint/BuildingUse/> .
@prefix edintceekos-es: <http://vocab.linkeddata.es/datosabiertos/kos/edint/EnergySource/> .
@prefix edintceekos-cz: <http://vocab.linkeddata.es/datosabiertos/kos/edint/ClimaticZone/> .
@prefix edintceekos-rsv: <http://vocab.linkeddata.es/datosabiertos/kos/edint/RatingScaleVersion/> .
@prefix edintceekos-ct: <http://vocab.linkeddata.es/datosabiertos/kos/edint/CertificateType/> .
@prefix edintceekos-rl: <http://vocab.linkeddata.es/datosabiertos/kos/edint/RatingLetter/> .
@prefix edintceekos-rt: <http://vocab.linkeddata.es/datosabiertos/kos/edint/RecommendationType/> .
@prefix edintceekos-pt: <http://vocab.linkeddata.es/datosabiertos/kos/edint/ProcedureType/> .
@prefix edintceekos-rcp: <http://vocab.linkeddata.es/datosabiertos/kos/edint/RecipientType/> .
@prefix edintceekos-db: <http://vocab.linkeddata.es/datosabiertos/kos/edint/DataBasis/> .
@prefix edintceekos-ap: <http://vocab.linkeddata.es/datosabiertos/kos/edint/AccessPath/> .
@prefix edintceekos-cm: <http://vocab.linkeddata.es/datosabiertos/kos/edint/CourseModule/> .
@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .
@prefix esdir: <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#> .
@prefix schema: <http://schema.org/> .
@prefix esadm: <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#> .
@prefix catastro: <http://vocab.linkeddata.es/datosabiertos/def/catastro/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .

# =============================================================================
# ONTOLOGY METADATA
# =============================================================================

<http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/> a owl:Ontology ;
    owl:versionIRI <http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/0.1.0> ;
    owl:versionInfo "0.1.0" ;
    dcterms:title "Ontología de Certificados de Eficiencia Energética de Edificios"@es ;
    dcterms:title "Energy Performance Certificate Ontology for Buildings"@en ;
    dcterms:description "Ontología que modela los certificados de eficiencia energética de edificios según el Real Decreto 390/2021. La clase raíz es EnergyCertificate; el edificio es una entidad externa que apunta al certificado mediante una propiedad definida en su propia ontología."@es ;
    dcterms:description "An ontology modelling energy performance certificates for buildings according to Spanish Royal Decree 390/2021. The root class is EnergyCertificate; the building is an external entity that points to the certificate via a property defined in its own ontology."@en ;
    dcterms:abstract "Ontología centrada en el certificado de eficiencia energética como unidad documental, incluyendo calificación energética, etiqueta, técnico competente, recomendaciones de mejora, procedimiento de cálculo y recomendaciones de uso para el usuario."@es ;
    dcterms:abstract "Ontology focused on the energy performance certificate as a documentary unit, including energy rating, label, competent technician, improvement recommendations, calculation procedure and user recommendations."@en ;
    dcterms:issued "2026-05-14"^^xsd:date ;
    dcterms:created "2026-05-14"^^xsd:date ;
    dcterms:modified "2026-05-14"^^xsd:date ;
    dcterms:creator "FEMP" ,
                    "Oscar Corcho" ,
                    "Edna Ruckhaus" ,
                    "Daniel Doña" ,
                    "Lucía Sánchez" ,
                    "Maria del Socorro Bernardos" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:hasFormat <http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/ontology.ttl> ;
    vann:preferredNamespacePrefix "edintcee" ;
    vann:preferredNamespaceUri "http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/" ;
    rdfs:comment "Versión inicial (core) centrada en las clases principales: EnergyCertificate, EnergyRating, EnergyLabel, CompetentTechnician, ImprovementRecommendation, CalculationProcedure y UserRecommendations, con sus relaciones y propiedades."@es ;
    rdfs:comment "Initial (core) version focusing on the main classes: EnergyCertificate, EnergyRating, EnergyLabel, CompetentTechnician, ImprovementRecommendation, CalculationProcedure and UserRecommendations, with their relationships and properties."@en ;
    rdfs:seeAlso <https://www.boe.es/eli/es/rd/2021/06/01/390> .

# =============================================================================
# CLASSES
# =============================================================================

# --- Root Class ---

edintcee:EnergyCertificate a owl:Class ;
    rdfs:label "Certificado de eficiencia energética"@es ;
    rdfs:label "Energy performance certificate"@en ;
    rdfs:comment "Documentación suscrita por un técnico competente que contiene la calificación de eficiencia energética de un edificio o parte del mismo, sus características energéticas y recomendaciones de mejora (Art. 2.e-g, RD 390/2021)."@es ;
    rdfs:comment "Documentation signed by a competent technician containing the energy performance rating of a building or part thereof, its energy characteristics and improvement recommendations (Art. 2.e-g, RD 390/2021)."@en ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty edintcee:hasRating ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass edintcee:EnergyRating
    ] , [
        a owl:Restriction ;
        owl:onProperty edintcee:issuedBy ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass edintcee:CompetentTechnician
    ] , [
        a owl:Restriction ;
        owl:onProperty edintcee:usesProcedure ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass edintcee:CalculationProcedure
    ] , [
        a owl:Restriction ;
        owl:onProperty edintcee:hasUserRecommendations ;
        owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass edintcee:UserRecommendations
    ] , [
        a owl:Restriction ;
        owl:onProperty edintcee:certificateType ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass skos:Concept
    ] , [
        a owl:Restriction ;
        owl:onProperty edintcee:issueDate ;
        owl:cardinality "1"^^xsd:nonNegativeInteger
    ] , [
        a owl:Restriction ;
        owl:onProperty edintcee:validUntil ;
        owl:cardinality "1"^^xsd:nonNegativeInteger
    ] .

# --- Supporting Classes ---

edintcee:EnergyRating a owl:Class ;
    rdfs:label "Calificación energética"@es ;
    rdfs:label "Energy rating"@en ;
    rdfs:comment "Expresión de la eficiencia energética de un edificio mediante indicadores numéricos de consumo y emisiones, resumida en una letra de la escala A-G (Art. 2.a)."@es ;
    rdfs:comment "Expression of the energy efficiency of a building through numerical consumption and emission indicators, summarised as a letter on the A-G scale (Art. 2.a)."@en ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty edintcee:ratingLetter ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass skos:Concept
    ] , [
        a owl:Restriction ;
        owl:onProperty edintcee:ratingScaleVersion ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass skos:Concept
    ] , [
        a owl:Restriction ;
        owl:onProperty edintcee:primaryEnergyNonRenewable ;
        owl:cardinality "1"^^xsd:nonNegativeInteger
    ] , [
        a owl:Restriction ;
        owl:onProperty edintcee:co2Emissions ;
        owl:cardinality "1"^^xsd:nonNegativeInteger
    ] .

edintcee:EnergyLabel a owl:Class ;
    rdfs:label "Etiqueta de eficiencia energética"@es ;
    rdfs:label "Energy label"@en ;
    rdfs:comment "Distintivo asociado a un certificado registrado que acredita públicamente la calificación energética obtenida (Art. 2.ñ, Art. 15)."@es ;
    rdfs:comment "Distinctive mark associated with a registered certificate that publicly attests to the energy rating obtained (Art. 2.ñ, Art. 15)."@en .

edintcee:CompetentTechnician a owl:Class ;
    rdfs:label "Técnico competente"@es ;
    rdfs:label "Competent technician"@en ;
    rdfs:comment "Técnico habilitado para realizar la certificación de eficiencia energética de edificios (Art. 4 bis)."@es ;
    rdfs:comment "Technician qualified to carry out energy performance certification of buildings (Art. 4 bis)."@en .

edintcee:ImprovementRecommendation a owl:Class ;
    rdfs:label "Recomendación de mejora"@es ;
    rdfs:label "Improvement recommendation"@en ;
    rdfs:comment "Intervención técnicamente viable para la mejora de los niveles óptimos o rentables de la eficiencia energética, incluyendo estimación de costes y plazos de recuperación (Art. 8.2.f)."@es ;
    rdfs:comment "Technically viable intervention for improving optimal or cost-effective energy efficiency levels, including cost estimates and payback periods (Art. 8.2.f)."@en .

edintcee:CalculationProcedure a owl:Class ;
    rdfs:label "Procedimiento de cálculo"@es ;
    rdfs:label "Calculation procedure"@en ;
    rdfs:comment "Procedimiento reconocido (general o simplificado) inscrito en el Registro general de documentos reconocidos, utilizado para obtener la calificación de eficiencia energética (Art. 4.2.a, Art. 5)."@es ;
    rdfs:comment "Recognised procedure (general or simplified) registered in the general registry of recognised documents, used to obtain the energy performance rating (Art. 4.2.a, Art. 5)."@en .

edintcee:UserRecommendations a owl:Class ;
    rdfs:label "Recomendaciones de uso para el usuario"@es ;
    rdfs:label "User recommendations"@en ;
    rdfs:comment "Documento con recomendaciones para el usuario/arrendatario del edificio sobre cómo utilizar el edificio y sus sistemas para lograr la máxima eficiencia energética (Art. 8.1.f)."@es ;
    rdfs:comment "Document with recommendations for the building user/tenant on how to use the building and its systems to achieve optimal energy efficiency (Art. 8.1.f)."@en .

# --- Reused external classes ---

esdir:DireccionPostal a owl:Class ;
    rdfs:label "Dirección postal"@es ;
    rdfs:label "Postal address"@en ;
    rdfs:comment "Dirección postal en España. Especialización de schema:PostalAddress, vcard:Address y locn:Address. Permite representar una dirección con propiedades como schema:streetAddress, schema:addressLocality, schema:addressRegion y schema:postalCode."@es ;
    rdfs:comment "Postal address in Spain. Specialisation of schema:PostalAddress, vcard:Address and locn:Address. Allows representing an address with properties like schema:streetAddress, schema:addressLocality, schema:addressRegion and schema:postalCode."@en ;
    rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal> .

schema:PostalAddress a owl:Class ;
    rdfs:label "Dirección postal (schema)"@es ;
    rdfs:label "Postal address (schema)"@en ;
    rdfs:comment "Dirección postal según schema.org."@es ;
    rdfs:comment "Postal address according to schema.org."@en ;
    rdfs:isDefinedBy <http://schema.org/> .

esadm:Autonomia a owl:Class ;
    rdfs:label "Autonomía"@es ;
    rdfs:label "Autonomous community"@en ;
    rdfs:comment "Comunidad Autónoma o Ciudad Autónoma del territorio español."@es ;
    rdfs:comment "Autonomous Community or Autonomous City in the Spanish territory."@en ;
    rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> .

catastro:CadastralProperty a owl:Class ;
    rdfs:label "Inmueble catastral"@es ;
    rdfs:label "Cadastral property"@en ;
    rdfs:comment "Unidad catastral que identifica un inmueble (parcela, construcción o unidad funcional) en el catastro. Permite acceder a la referencia catastral, dirección, año de construcción, superficie y geometría."@es ;
    rdfs:comment "Cadastral unit that identifies a property (parcel, construction or functional unit) in the cadastre. Allows access to the cadastral reference, address, construction year, surface area and geometry."@en ;
    rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/catastro/> .

qudt:QuantityValue a owl:Class ;
    rdfs:label "Valor de cantidad"@es ;
    rdfs:label "Quantity value"@en ;
    rdfs:comment "Valor numérico con unidad de medida explícita (qudt:numericValue + qudt:hasUnit). Permite representar magnitudes físicas como energía (kWh/m²·año), emisiones (kgCO2/m²·año), potencia (kW), superficie (m²), porcentaje, etc."@es ;
    rdfs:comment "Numeric value with explicit unit of measure (qudt:numericValue + qudt:hasUnit). Allows representing physical quantities such as energy (kWh/m²·year), emissions (kgCO2/m²·year), power (kW), area (m²), percentage, etc."@en ;
    rdfs:isDefinedBy <http://qudt.org/schema/qudt/> .

# --- Datatype enumerations ---





# =============================================================================
# OBJECT PROPERTIES
# =============================================================================

# --- Core relationships ---

edintcee:hasRating a owl:ObjectProperty ;
    rdfs:label "tiene calificación"@es ;
    rdfs:label "has rating"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range edintcee:EnergyRating ;
    rdfs:comment "Vincula un certificado a sus indicadores de calificación energética."@es ;
    rdfs:comment "Links a certificate to its energy rating indicators."@en ;
    owl:inverseOf edintcee:ratingOf .

edintcee:issuedBy a owl:ObjectProperty ;
    rdfs:label "emitido por"@es ;
    rdfs:label "issued by"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range edintcee:CompetentTechnician ;
    rdfs:comment "Técnico competente que suscribe el certificado."@es ;
    rdfs:comment "Competent technician who signs the certificate."@en ;
    owl:inverseOf edintcee:issuedCertificate .

edintcee:hasLabel a owl:ObjectProperty ;
    rdfs:label "tiene etiqueta"@es ;
    rdfs:label "has label"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range edintcee:EnergyLabel ;
    rdfs:comment "Etiqueta de eficiencia energética asociada al certificado registrado."@es ;
    rdfs:comment "Energy label associated with the registered certificate."@en ;
    owl:inverseOf edintcee:labelFor .

edintcee:hasRecommendation a owl:ObjectProperty ;
    rdfs:label "tiene recomendación"@es ;
    rdfs:label "has recommendation"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range edintcee:ImprovementRecommendation ;
    rdfs:comment "Recomendación de mejora incluida en el certificado."@es ;
    rdfs:comment "Improvement recommendation included in the certificate."@en ;
    owl:inverseOf edintcee:recommendationFor .

edintcee:usesProcedure a owl:ObjectProperty ;
    rdfs:label "usa procedimiento"@es ;
    rdfs:label "uses procedure"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range edintcee:CalculationProcedure ;
    rdfs:comment "Procedimiento de cálculo reconocido utilizado para obtener la calificación."@es ;
    rdfs:comment "Recognised calculation procedure used to obtain the rating."@en ;
    owl:inverseOf edintcee:procedureUsedBy .

edintcee:predecessorCertificate a owl:ObjectProperty ;
    rdfs:label "certificado anterior"@es ;
    rdfs:label "predecessor certificate"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range edintcee:EnergyCertificate ;
    rdfs:comment "Certificado anterior que este certificado renueva o reemplaza."@es ;
    rdfs:comment "Previous certificate that this certificate renews or replaces."@en ;
    owl:inverseOf edintcee:successorCertificate .

edintcee:hasUserRecommendations a owl:ObjectProperty ;
    rdfs:label "tiene recomendaciones de uso"@es ;
    rdfs:label "has user recommendations"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range edintcee:UserRecommendations ;
    rdfs:comment "Documento de recomendaciones de uso entregado al usuario/arrendatario del edificio (Art. 8.1.f)."@es ;
    rdfs:comment "User recommendations document delivered to the building user/tenant (Art. 8.1.f)."@en .

# --- Certificate type (SKOS-controlled) ---

edintcee:certificateType a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "tipo de certificado"@es ;
    rdfs:label "certificate type"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:CertificateType
            ]
        )
    ] ;
    rdfs:comment "Tipo de certificado de eficiencia energética según el vocabulario controlado de tipos de certificado: proyecto, obra terminada o edificio existente (Art. 2.b-g, Art. 9-10, Art. 15.2 RD 390/2021)."@es ;
    rdfs:comment "Type of energy performance certificate according to the certificate-type controlled vocabulary: project, completed work or existing building (Art. 2.b-g, Art. 9-10, Art. 15.2 RD 390/2021)."@en .

# --- SKOS-controlled properties ---

edintcee:observedBuildingUse a owl:ObjectProperty ;
    rdfs:label "uso del edificio observado"@es ;
    rdfs:label "observed building use"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:BuildingUse
            ]
        )
    ] ;
    rdfs:comment "Uso del edificio según el vocabulario controlado de usos de edificio."@es ;
    rdfs:comment "Building use according to the building-use controlled vocabulary."@en .

edintcee:observedClimaticZone a owl:ObjectProperty ;
    rdfs:label "zona climática observada"@es ;
    rdfs:label "observed climatic zone"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:ClimaticZone
            ]
        )
    ] ;
    rdfs:comment "Zona climática según el vocabulario controlado de zonas climáticas."@es ;
    rdfs:comment "Climatic zone according to the climatic-zone controlled vocabulary."@en .

edintcee:heatingEnergySource a owl:ObjectProperty ;
    rdfs:label "fuente energética de calefacción"@es ;
    rdfs:label "heating energy source"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:EnergySource
            ]
        )
    ] ;
    rdfs:comment "Fuente de energía del sistema de calefacción según el vocabulario controlado de fuentes de energía."@es ;
    rdfs:comment "Energy source of the heating system according to the energy-source controlled vocabulary."@en .

edintcee:coolingEnergySource a owl:ObjectProperty ;
    rdfs:label "fuente energética de refrigeración"@es ;
    rdfs:label "cooling energy source"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:EnergySource
            ]
        )
    ] ;
    rdfs:comment "Fuente de energía del sistema de refrigeración según el vocabulario controlado de fuentes de energía."@es ;
    rdfs:comment "Energy source of the cooling system according to the energy-source controlled vocabulary."@en .

edintcee:dhwEnergySource a owl:ObjectProperty ;
    rdfs:label "fuente energética de ACS"@es ;
    rdfs:label "DHW energy source"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:EnergySource
            ]
        )
    ] ;
    rdfs:comment "Fuente de energía del sistema de agua caliente sanitaria según el vocabulario controlado de fuentes de energía."@es ;
    rdfs:comment "Energy source of the domestic hot water system according to the energy-source controlled vocabulary."@en .

edintcee:ventilationEnergySource a owl:ObjectProperty ;
    rdfs:label "fuente energética de ventilación"@es ;
    rdfs:label "ventilation energy source"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:EnergySource
            ]
        )
    ] ;
    rdfs:comment "Fuente de energía del sistema de ventilación según el vocabulario controlado de fuentes de energía."@es ;
    rdfs:comment "Energy source of the ventilation system according to the energy-source controlled vocabulary."@en .

edintcee:renewableEnergySource a owl:ObjectProperty ;
    rdfs:label "fuente de energía renovable"@es ;
    rdfs:label "renewable energy source"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:EnergySource
            ]
        )
    ] ;
    rdfs:comment "Tipo de fuente de energía renovable según el vocabulario controlado de fuentes de energía."@es ;
    rdfs:comment "Type of renewable energy source according to the energy-source controlled vocabulary."@en .

# --- Rating scale version (SKOS-controlled) ---

edintcee:ratingScaleVersion a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "versión de la escala de calificación"@es ;
    rdfs:label "rating scale version"@en ;
    rdfs:domain edintcee:EnergyRating ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:RatingScaleVersion
            ]
        )
    ] ;
    rdfs:comment "Versión de la escala de calificación energética aplicada, según el vocabulario controlado de versiones de escala. Permite distinguir entre la escala original del RD 390/2021 y la escala recalculada conforme a la Directiva (UE) 2024/1275 (EPBD III)."@es ;
    rdfs:comment "Version of the energy rating scale applied, according to the rating-scale-version controlled vocabulary. Allows distinguishing between the original scale from RD 390/2021 and the recalculated scale per Directive (EU) 2024/1275 (EPBD III)."@en .

# --- Inverse properties ---

edintcee:ratingOf a owl:ObjectProperty ;
    rdfs:label "calificación de"@es ;
    rdfs:label "rating of"@en ;
    rdfs:domain edintcee:EnergyRating ;
    rdfs:range edintcee:EnergyCertificate ;
    rdfs:comment "Certificado al que pertenece esta calificación."@es ;
    rdfs:comment "Certificate this rating belongs to."@en .

edintcee:issuedCertificate a owl:ObjectProperty ;
    rdfs:label "certificado emitido"@es ;
    rdfs:label "issued certificate"@en ;
    rdfs:domain edintcee:CompetentTechnician ;
    rdfs:range edintcee:EnergyCertificate ;
    rdfs:comment "Certificado emitido por este técnico."@es ;
    rdfs:comment "Certificate issued by this technician."@en .

edintcee:labelFor a owl:ObjectProperty ;
    rdfs:label "etiqueta para"@es ;
    rdfs:label "label for"@en ;
    rdfs:domain edintcee:EnergyLabel ;
    rdfs:range edintcee:EnergyCertificate ;
    rdfs:comment "Certificado al que corresponde esta etiqueta."@es ;
    rdfs:comment "Certificate this label belongs to."@en .

edintcee:recommendationFor a owl:ObjectProperty ;
    rdfs:label "recomendación para"@es ;
    rdfs:label "recommendation for"@en ;
    rdfs:domain edintcee:ImprovementRecommendation ;
    rdfs:range edintcee:EnergyCertificate ;
    rdfs:comment "Certificado al que pertenece esta recomendación."@es ;
    rdfs:comment "Certificate this recommendation belongs to."@en .

edintcee:procedureUsedBy a owl:ObjectProperty ;
    rdfs:label "procedimiento usado por"@es ;
    rdfs:label "procedure used by"@en ;
    rdfs:domain edintcee:CalculationProcedure ;
    rdfs:range edintcee:EnergyCertificate ;
    rdfs:comment "Certificado que utiliza este procedimiento."@es ;
    rdfs:comment "Certificate that uses this procedure."@en .

edintcee:successorCertificate a owl:ObjectProperty ;
    rdfs:label "certificado sucesor"@es ;
    rdfs:label "successor certificate"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range edintcee:EnergyCertificate ;
    rdfs:comment "Certificado que reemplaza o renueva este certificado."@es ;
    rdfs:comment "Certificate that renews or replaces this certificate."@en .

# =============================================================================
# DATATYPE PROPERTIES — Certificate metadata
# =============================================================================

edintcee:certificateNumber a owl:DatatypeProperty ;
    rdfs:label "número de certificado"@es ;
    rdfs:label "certificate number"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:string ;
    rdfs:comment "Número de registro del certificado en la comunidad autónoma (Art. 6.6)."@es ;
    rdfs:comment "Certificate registration number in the autonomous community (Art. 6.6)."@en .

edintcee:issueDate a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "fecha de emisión"@es ;
    rdfs:label "issue date"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:date ;
    rdfs:comment "Fecha en la que el técnico competente suscribe el certificado."@es ;
    rdfs:comment "Date on which the competent technician signs the certificate."@en .

edintcee:visitDate a owl:DatatypeProperty ;
    rdfs:label "fecha de visita"@es ;
    rdfs:label "visit date"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:date ;
    rdfs:comment "Fecha de la visita in situ al edificio (Art. 6.5, Art. 8.2.g)."@es ;
    rdfs:comment "Date of the on-site visit to the building (Art. 6.5, Art. 8.2.g)."@en .

edintcee:registrationDate a owl:DatatypeProperty ;
    rdfs:label "fecha de registro"@es ;
    rdfs:label "registration date"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:date ;
    rdfs:comment "Fecha en la que el certificado se registra en el órgano competente de la CCAA (Art. 6.6)."@es ;
    rdfs:comment "Date on which the certificate is registered with the competent authority of the autonomous community (Art. 6.6)."@en .

edintcee:validUntil a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "válido hasta"@es ;
    rdfs:label "valid until"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:date ;
    rdfs:comment "Fecha de caducidad del certificado, máximo 10 años desde la emisión (Art. 13)."@es ;
    rdfs:comment "Expiry date of the certificate, maximum 10 years from issue (Art. 13)."@en .

edintcee:visitDescription a owl:DatatypeProperty ;
    rdfs:label "descripción de la visita"@es ;
    rdfs:label "visit description"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:string ;
    rdfs:comment "Descripción de la visita in situ realizada (Art. 8.2.g)."@es ;
    rdfs:comment "Description of the on-site visit carried out (Art. 8.2.g)."@en .

edintcee:applicableRegulation a owl:DatatypeProperty ;
    rdfs:label "normativa aplicable"@es ;
    rdfs:label "applicable regulation"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:string ;
    rdfs:comment "Normativa aplicada en la evaluación (Art. 8.2.c)."@es ;
    rdfs:comment "Regulation applied in the evaluation (Art. 8.2.c)."@en .

edintcee:registrationAutonomousCommunity a owl:ObjectProperty ;
    rdfs:label "CCAA de registro"@es ;
    rdfs:label "registration autonomous community"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range esadm:Autonomia ;
    rdfs:comment "Comunidad autónoma donde se registra el certificado, representada como esadm:Autonomia del vocabulario de territorio (Art. 6.6)."@es ;
    rdfs:comment "Autonomous community where the certificate is registered, represented as esadm:Autonomia from the territory vocabulary (Art. 6.6)."@en .

# --- Verification & Registration ---

edintcee:registryURL a owl:DatatypeProperty ;
    rdfs:label "URL del registro"@es ;
    rdfs:label "registry URL"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:anyURI ;
    rdfs:comment "URL del certificado en el registro autonómico."@es ;
    rdfs:comment "URL of the certificate in the autonomous registry."@en .

edintcee:certificateHash a owl:DatatypeProperty ;
