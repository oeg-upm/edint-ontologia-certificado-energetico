    rdfs:label "financing information"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:string ;
    rdfs:comment "Información sobre incentivos financieros, ayudas o posibilidad de financiación para las mejoras recomendadas."@es ;
    rdfs:comment "Information about financial incentives, grants or financing possibilities for recommended improvements."@en .

edintcee:consumptionDataAvailableToOwner a owl:DatatypeProperty ;
    rdfs:label "datos de consumo disponibles para el propietario"@es ;
    rdfs:label "consumption data available to owner"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Los datos de consumo están disponibles para el propietario del edificio (Art. 6.7)."@es ;
    rdfs:comment "Consumption data is available to the building owner (Art. 6.7)."@en .

edintcee:aggregatedDataAvailableForResearch a owl:DatatypeProperty ;
    rdfs:label "datos agregados disponibles para investigación"@es ;
    rdfs:label "aggregated data available for research"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Los datos agregados y anonimizados están disponibles para uso estadístico y de investigación (Art. 6.7)."@es ;
    rdfs:comment "Aggregated and anonymized data are available for statistical and research use (Art. 6.7)."@en .

edintcee:noImprovementJustification a owl:DatatypeProperty ;
    rdfs:label "justificación de inexistencia de potencial de mejora"@es ;
    rdfs:label "no improvement potential justification"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:string ;
    rdfs:comment "Justificación técnica de la inexistencia de potencial razonable para la mejora (Art. 8.2.f)."@es ;
    rdfs:comment "Technical justification for the absence of reasonable improvement potential (Art. 8.2.f)."@en .

# =============================================================================
# DATATYPE PROPERTIES — Observed building data
# =============================================================================

edintcee:refersToCadastralEntity a owl:ObjectProperty ;
    rdfs:label "entidad catastral referida"@es ;
    rdfs:label "refers to cadastral entity"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range catastro:CadastralProperty ;
    rdfs:comment "Entidad catastral a la que se refiere el certificado. A través de catastro:CadastralProperty se puede acceder a la referencia catastral (catastro:referenceCatastral), la dirección (catastro:hasAddress), el año de construcción y otros datos del inmueble (Art. 8.2.a)."@es ;
    rdfs:comment "Cadastral entity the certificate refers to. Through catastro:CadastralProperty, the cadastral reference (catastro:referenceCatastral), address (catastro:hasAddress), construction year and other property data can be accessed (Art. 8.2.a)."@en .

edintcee:hasObservedAddress a owl:ObjectProperty ;
    rdfs:label "dirección del inmueble"@es ;
    rdfs:label "observed address"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range esdir:DireccionPostal ;
    rdfs:comment "Dirección postal del inmueble certificado. Se reutiliza esdir:DireccionPostal, que especializa schema:PostalAddress, vcard:Address y locn:Address, y permite representar vía, municipio, provincia y código postal con propiedades estándar (Art. 8.2.a)."@es ;
    rdfs:comment "Postal address of the certified property. Reuses esdir:DireccionPostal, which specialises schema:PostalAddress, vcard:Address and locn:Address, and allows representing street, municipality, province and postal code with standard properties (Art. 8.2.a)."@en .

edintcee:observedHeritageProtection a owl:DatatypeProperty ;
    rdfs:label "protección patrimonial observada"@es ;
    rdfs:label "observed heritage protection"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Si el edificio tiene protección patrimonial (Art. 3.2.a)."@es ;
    rdfs:comment "Whether the building has heritage protection (Art. 3.2.a)."@en .

edintcee:observedIsBuildingPart a owl:DatatypeProperty ;
    rdfs:label "es parte de edificio"@es ;
    rdfs:label "is building part"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Indica si la certificación se refiere a una parte de un edificio."@es ;
    rdfs:comment "Indicates whether the certification refers to a part of a building."@en .

edintcee:observedPartDescription a owl:DatatypeProperty ;
    rdfs:label "descripción de la parte"@es ;
    rdfs:label "part description"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:string ;
    rdfs:comment "Descripción de la parte del edificio certificada (vivienda, local, etc.)."@es ;
    rdfs:comment "Description of the certified part of the building (dwelling, premises, etc.)."@en .

# =============================================================================
# DATATYPE PROPERTIES — Energy characteristics (envelope & systems)
# =============================================================================

edintcee:envelopeDescription a owl:DatatypeProperty ;
