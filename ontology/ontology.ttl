    rdfs:comment "Recognised procedure type: general or simplified, according to the procedure-type controlled vocabulary."@en .

# =============================================================================
# DATATYPE PROPERTIES — UserRecommendations
# =============================================================================

edintcee:userRecommendationsDelivered a owl:DatatypeProperty ;
    rdfs:label "recomendaciones entregadas"@es ;
    rdfs:label "recommendations delivered"@en ;
    rdfs:domain edintcee:UserRecommendations ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Si el documento de recomendaciones de uso fue entregado al arrendatario/propietario."@es ;
    rdfs:comment "Whether the user recommendations document was delivered to the tenant/owner."@en .

edintcee:userRecommendationsDeliveryDate a owl:DatatypeProperty ;
    rdfs:label "fecha de entrega de recomendaciones"@es ;
    rdfs:label "recommendations delivery date"@en ;
    rdfs:domain edintcee:UserRecommendations ;
    rdfs:range xsd:date ;
    rdfs:comment "Fecha en la que se entregaron las recomendaciones de uso."@es ;
    rdfs:comment "Date on which the user recommendations were delivered."@en .

edintcee:userRecommendationsRecipient a owl:ObjectProperty ;
    rdfs:label "destinatario de recomendaciones"@es ;
    rdfs:label "recommendations recipient"@en ;
    rdfs:domain edintcee:UserRecommendations ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:RecipientType
            ]
        )
    ] ;
    rdfs:comment "Destinatario de las recomendaciones: propietario, arrendatario o ambos, según el vocabulario controlado de tipos de destinatario."@es ;
    rdfs:comment "Recipient of the recommendations: owner, tenant, or both, according to the recipient-type controlled vocabulary."@en .

