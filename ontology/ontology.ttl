    rdfs:label "envelope description"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:string ;
    rdfs:comment "Descripción de la envolvente térmica del edificio (Art. 8.2.d)."@es ;
    rdfs:comment "Description of the thermal envelope of the building (Art. 8.2.d)."@en .

edintcee:envelopeArea a owl:ObjectProperty ;
    rdfs:label "superficie de envolvente"@es ;
    rdfs:label "envelope area"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range qudt:QuantityValue ;
    rdfs:comment "Superficie de la envolvente térmica en contacto con el exterior. Se expresa como qudt:QuantityValue (qudt:numericValue + qudt:hasUnit), típicamente en m²."@es ;
    rdfs:comment "Surface area of the thermal envelope in contact with the exterior. Expressed as qudt:QuantityValue (qudt:numericValue + qudt:hasUnit), typically in m²."@en .

edintcee:globalHeatTransferCoeff a owl:ObjectProperty ;
    rdfs:label "coeficiente global de transmitancia"@es ;
    rdfs:label "global heat transfer coefficient"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range qudt:QuantityValue ;
    rdfs:comment "Coeficiente global de transmitancia térmica U de la envolvente. Se expresa como qudt:QuantityValue, típicamente en W/m²·K."@es ;
    rdfs:comment "Global thermal transmittance coefficient U of the envelope. Expressed as qudt:QuantityValue, typically in W/m²·K."@en .

edintcee:thermalBridgeLosses a owl:ObjectProperty ;
    rdfs:label "pérdidas por puentes térmicos lineales"@es ;
    rdfs:label "linear thermal bridge losses"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range qudt:QuantityValue ;
    rdfs:comment "Pérdidas por puentes térmicos lineales. Se expresa como qudt:QuantityValue, típicamente en W/K."@es ;
    rdfs:comment "Linear thermal bridge losses. Expressed as qudt:QuantityValue, typically in W/K."@en .

edintcee:windowAreaRatio a owl:ObjectProperty ;
    rdfs:label "ratio huecos/fachada"@es ;
    rdfs:label "window-to-wall ratio"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range qudt:QuantityValue ;
    rdfs:comment "Porcentaje de huecos/acristalamiento sobre fachada. Se expresa como qudt:QuantityValue, típicamente en porcentaje."@es ;
    rdfs:comment "Percentage of glazing/openings relative to facade area. Expressed as qudt:QuantityValue, typically in percent."@en .

edintcee:architecturalProtectionType a owl:DatatypeProperty ;
    rdfs:label "tipo de protección arquitectónica"@es ;
    rdfs:label "architectural protection type"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:string ;
    rdfs:comment "Tipo y nivel de catalogación arquitectónica (ej: 'Bien de Interés Cultural', 'Protegido por PGOU')."@es ;
    rdfs:comment "Type and level of architectural catalogation/protection."@en .

edintcee:normalOperatingConditions a owl:DatatypeProperty ;
    rdfs:label "condiciones normales de funcionamiento"@es ;
    rdfs:label "normal operating conditions"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:string ;
    rdfs:comment "Condiciones normales de funcionamiento del edificio utilizadas para la calificación (Art. 8.2.d)."@es ;
    rdfs:comment "Normal operating conditions of the building used for the energy rating (Art. 8.2.d)."@en .

edintcee:comfortConditions a owl:DatatypeProperty ;
    rdfs:label "condiciones de confort"@es ;
    rdfs:label "comfort conditions"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:string ;
    rdfs:comment "Condiciones de confort consideradas en la evaluación energética (Art. 8.2.d)."@es ;
    rdfs:comment "Comfort conditions considered in the energy evaluation (Art. 8.2.d)."@en .

edintcee:linkedToBuildingBook a owl:DatatypeProperty ;
    rdfs:label "vinculado al Libro del Edificio"@es ;
    rdfs:label "linked to Building Book"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Si el certificado está incorporado al Libro del Edificio (Art. 6.8)."@es ;
    rdfs:comment "Whether the certificate is included in the Building Book (Art. 6.8)."@en .

edintcee:representativeBuildingReference a owl:DatatypeProperty ;
    rdfs:label "referencia del edificio representativo"@es ;
    rdfs:label "representative building reference"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:string ;
    rdfs:comment "Referencia del edificio representativo utilizado para la certificación (viviendas unifamiliares) (Art. 6.3)."@es ;
    rdfs:comment "Reference to the representative building used for certification (single-family homes) (Art. 6.3)."@en .

edintcee:usesSameProcedureVersion a owl:DatatypeProperty ;
    rdfs:label "usa misma versión del procedimiento"@es ;
    rdfs:label "uses same procedure version"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:boolean ;
    rdfs:comment "En la comparación proyecto→obra terminada, se usa la misma versión del documento reconocido (Art. 9.4)."@es ;
    rdfs:comment "When comparing project→completed work certificates, the same version of the recognized document is used (Art. 9.4)."@en .

