    rdfs:label "total measured consumption (kWh/m²·year)"@en ;
    rdfs:domain edintcee:EnergyRating ;
    rdfs:range xsd:decimal .

edintcee:measurementPeriodStart a owl:DatatypeProperty ;
    rdfs:label "fecha inicio periodo de medición"@es ;
    rdfs:label "measurement period start"@en ;
    rdfs:domain edintcee:EnergyRating ;
    rdfs:range xsd:date .

edintcee:measurementPeriodEnd a owl:DatatypeProperty ;
    rdfs:label "fecha fin periodo de medición"@es ;
    rdfs:label "measurement period end"@en ;
    rdfs:domain edintcee:EnergyRating ;
    rdfs:range xsd:date .

edintcee:dataBasis a owl:DatatypeProperty ;
    rdfs:label "base de datos"@es ;
    rdfs:label "data basis"@en ;
    rdfs:domain edintcee:EnergyRating ;
    rdfs:range xsd:string ;
    rdfs:comment "Indica si los indicadores se basan en datos medidos o calculados: 'measured', 'calculated', 'mixed'."@es ;
    rdfs:comment "Indicates whether indicators are based on measured or calculated data: 'measured', 'calculated', 'mixed'."@en .

