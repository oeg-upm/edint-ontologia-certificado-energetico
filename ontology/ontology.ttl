    rdfs:label "XML report reference"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:anyURI ;
    rdfs:comment "Referencia al informe de evaluación energética en formato electrónico (XML) (Art. 8.1.c)."@es ;
    rdfs:comment "Reference to the energy evaluation report in electronic format (XML) (Art. 8.1.c)."@en .

edintcee:calculationDocumentsReference a owl:DatatypeProperty ;
    rdfs:label "referencia a documentos de cálculo"@es ;
    rdfs:label "calculation documents reference"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:anyURI ;
    rdfs:comment "Referencia a documentos o ficheros digitales necesarios para la evaluación (Art. 8.1.d)."@es ;
    rdfs:comment "Reference to documents or digital files needed for the evaluation (Art. 8.1.d)."@en .

edintcee:costEffectivenessReference a owl:DatatypeProperty ;
    rdfs:label "referencia a análisis coste-eficacia"@es ;
    rdfs:label "cost-effectiveness analysis reference"@en ;
    rdfs:domain edintcee:EnergyCertificate ;
    rdfs:range xsd:anyURI ;
    rdfs:comment "Referencia al análisis coste-eficacia de las recomendaciones (Art. 8.2.f, Reglamento Delegado UE 244/2012)."@es ;
    rdfs:comment "Reference to the cost-effectiveness analysis of recommendations (Art. 8.2.f, Delegated Regulation EU 244/2012)."@en .

edintcee:financingInformation a owl:DatatypeProperty ;
