edintcee:dataBasis a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "base de datos"@es ;
    rdfs:label "data basis"@en ;
    rdfs:domain edintcee:EnergyRating ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:DataBasis
            ]
        )
    ] ;
    rdfs:comment "Indica si los indicadores se basan en datos medidos, calculados o mixtos, según el vocabulario controlado de tipos de base de datos (Art. 6.7)."@es ;
    rdfs:comment "Indicates whether indicators are based on measured, calculated or mixed data, according to the data-basis controlled vocabulary (Art. 6.7)."@en .

# =============================================================================
# DATATYPE PROPERTIES — ImprovementRecommendation
# =============================================================================

edintcee:recommendationType a owl:ObjectProperty ;
    rdfs:label "tipo de recomendación"@es ;
    rdfs:label "recommendation type"@en ;
    rdfs:domain edintcee:ImprovementRecommendation ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:RecommendationType
            ]
        )
    ] ;
    rdfs:comment "Ámbito de la intervención: envelope, installation, automation, combined, según el vocabulario controlado de tipos de recomendación (Art. 8.2.f)."@es ;
    rdfs:comment "Scope of the intervention: envelope, installation, automation, combined, according to the recommendation-type controlled vocabulary (Art. 8.2.f)."@en .

edintcee:recommendationDescription a owl:DatatypeProperty ;
    rdfs:label "descripción de la recomendación"@es ;
    rdfs:label "recommendation description"@en ;
    rdfs:domain edintcee:ImprovementRecommendation ;
    rdfs:range xsd:string .

edintcee:estimatedSavingPct a owl:ObjectProperty ;
    rdfs:label "ahorro estimado"@es ;
    rdfs:label "estimated saving"@en ;
    rdfs:domain edintcee:ImprovementRecommendation ;
    rdfs:range qudt:QuantityValue ;
    rdfs:comment "Ahorro estimado porcentual. Se expresa como qudt:QuantityValue, típicamente en porcentaje."@es ;
    rdfs:comment "Estimated percentage saving. Expressed as qudt:QuantityValue, typically in percent."@en .

edintcee:estimatedSavingKwh a owl:ObjectProperty ;
    rdfs:label "ahorro estimado en energía"@es ;
    rdfs:label "estimated saving in energy"@en ;
    rdfs:domain edintcee:ImprovementRecommendation ;
    rdfs:range qudt:QuantityValue ;
    rdfs:comment "Ahorro estimado en energía. Se expresa como qudt:QuantityValue, típicamente en kWh/año."@es ;
    rdfs:comment "Estimated energy saving. Expressed as qudt:QuantityValue, typically in kWh/year."@en .

edintcee:paybackPeriod a owl:ObjectProperty ;
    rdfs:label "plazo de recuperación"@es ;
    rdfs:label "payback period"@en ;
    rdfs:domain edintcee:ImprovementRecommendation ;
    rdfs:range qudt:QuantityValue ;
    rdfs:comment "Plazo de recuperación de la inversión. Se expresa como qudt:QuantityValue, típicamente en años."@es ;
    rdfs:comment "Payback period of the investment. Expressed as qudt:QuantityValue, typically in years."@en .

edintcee:estimatedCost a owl:ObjectProperty ;
    rdfs:label "coste estimado"@es ;
    rdfs:label "estimated cost"@en ;
    rdfs:domain edintcee:ImprovementRecommendation ;
    rdfs:range qudt:QuantityValue ;
    rdfs:comment "Coste estimado de la intervención. Se expresa como qudt:QuantityValue, típicamente en euros."@es ;
    rdfs:comment "Estimated cost of the intervention. Expressed as qudt:QuantityValue, typically in euros."@en .

edintcee:priority a owl:DatatypeProperty ;
    rdfs:label "prioridad"@es ;
    rdfs:label "priority"@en ;
    rdfs:domain edintcee:ImprovementRecommendation ;
    rdfs:range xsd:integer ;
    rdfs:comment "Orden de la recomendación en la secuencia temporal de aplicación (Art. 8.2.f.4º)."@es ;
    rdfs:comment "Order of the recommendation in the temporal sequence of application (Art. 8.2.f.4º)."@en .

edintcee:improvedRatingLetter a owl:ObjectProperty ;
    rdfs:label "calificación estimada tras mejora"@es ;
    rdfs:label "improved rating letter"@en ;
    rdfs:domain edintcee:ImprovementRecommendation ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:RatingLetter
            ]
        )
    ] ;
    rdfs:comment "Letra de calificación energética estimada tras la implementación de la recomendación, según el vocabulario controlado de letras de calificación."@es ;
    rdfs:comment "Estimated energy rating letter after implementation of the recommendation, according to the rating-letter controlled vocabulary."@en .

edintcee:comfortHealthBenefit a owl:DatatypeProperty ;
    rdfs:label "beneficio en confort/salud"@es ;
    rdfs:label "comfort/health benefit"@en ;
    rdfs:domain edintcee:ImprovementRecommendation ;
    rdfs:range xsd:string ;
    rdfs:comment "Mejoras en confort, salud o bienestar derivadas de la implementación (Art. 8.2.f)."@es ;
    rdfs:comment "Comfort, health or well-being improvements derived from implementation (Art. 8.2.f)."@en .

# =============================================================================
# DATATYPE PROPERTIES — CompetentTechnician
# =============================================================================

edintcee:technicianName a owl:DatatypeProperty ;
    rdfs:label "nombre del técnico"@es ;
    rdfs:label "technician name"@en ;
    rdfs:domain edintcee:CompetentTechnician ;
    rdfs:range xsd:string ;
    rdfs:comment "Nombre y apellidos del técnico competente (Anexo IV)."@es ;
    rdfs:comment "Full name of the competent technician (Annex IV)."@en .



edintcee:technicianNIF a owl:DatatypeProperty ;
    rdfs:label "NIF/NIE del técnico"@es ;
    rdfs:label "technician NIF/NIE"@en ;
    rdfs:domain edintcee:CompetentTechnician ;
    rdfs:range xsd:string .

edintcee:technicianQualification a owl:DatatypeProperty ;
    rdfs:label "titulación del técnico"@es ;
    rdfs:label "technician qualification"@en ;
    rdfs:domain edintcee:CompetentTechnician ;
    rdfs:range xsd:string ;
    rdfs:comment "Titulación académica que habilita al técnico (Art. 4 bis)."@es ;
    rdfs:comment "Academic qualification enabling the technician (Art. 4 bis)."@en .

edintcee:technicianRegistrationAutonomousCommunity a owl:ObjectProperty ;
    rdfs:label "CCAA de registro del técnico"@es ;
    rdfs:label "technician registration autonomous community"@en ;
    rdfs:domain edintcee:CompetentTechnician ;
    rdfs:range esadm:Autonomia ;
    rdfs:comment "Comunidad autónoma donde el técnico está registrado para certificar, representada como esadm:Autonomia del vocabulario de territorio."@es ;
    rdfs:comment "Autonomous community where the technician is registered to certify, represented as esadm:Autonomia from the territory vocabulary."@en .

edintcee:hasTechnicianAddress a owl:ObjectProperty ;
    rdfs:label "dirección del técnico"@es ;
    rdfs:label "technician address"@en ;
    rdfs:domain edintcee:CompetentTechnician ;
    rdfs:range esdir:DireccionPostal ;
    rdfs:comment "Dirección postal del técnico competente. Se reutiliza esdir:DireccionPostal, que especializa schema:PostalAddress, vcard:Address y locn:Address, y permite representar vía, municipio, provincia y código postal con propiedades estándar (Anexo IV)."@es ;
    rdfs:comment "Postal address of the competent technician. Reuses esdir:DireccionPostal, which specialises schema:PostalAddress, vcard:Address and locn:Address, and allows representing street, municipality, province and postal code with standard properties (Annex IV)."@en .

edintcee:technicianEmail a owl:DatatypeProperty ;
    rdfs:label "correo electrónico"@es ;
    rdfs:label "email"@en ;
    rdfs:domain edintcee:CompetentTechnician ;
    rdfs:range xsd:string .

edintcee:technicianPhone a owl:DatatypeProperty ;
    rdfs:label "teléfono"@es ;
    rdfs:label "phone"@en ;
    rdfs:domain edintcee:CompetentTechnician ;
    rdfs:range xsd:string .

edintcee:technicianAccessPath a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "vía de acceso"@es ;
    rdfs:label "access path"@en ;
    rdfs:domain edintcee:CompetentTechnician ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:AccessPath
            ]
        )
    ] ;
    rdfs:comment "Vía de acceso a la actividad de técnico competente según el vocabulario controlado de vías de acceso (Art. 4 bis)."@es ;
    rdfs:comment "Access path to the competent technician activity according to the access-path controlled vocabulary (Art. 4 bis)."@en .

edintcee:technicianCourseModules a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "módulos del curso cursados"@es ;
    rdfs:label "course modules completed"@en ;
    rdfs:domain edintcee:CompetentTechnician ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:CourseModule
            ]
        )
    ] ;
    rdfs:comment "Módulos del curso de conocimientos básicos, específicos y administrativos cursados, según el vocabulario controlado de módulos del curso (Art. 4 bis)."@es ;
    rdfs:comment "Modules of the basic, specific and administrative knowledge course completed, according to the course-module controlled vocabulary (Art. 4 bis)."@en .

edintcee:technicianPublicAuthorization a owl:DatatypeProperty ;
    rdfs:label "autorización para hacer público"@es ;
    rdfs:label "public authorization"@en ;
    rdfs:domain edintcee:CompetentTechnician ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Autorización voluntaria o rechazo para hacer público el nombre, apellidos y datos de contacto (Art. 4 quáter.4, Anexo IV)."@es ;
    rdfs:comment "Voluntary authorization or refusal to make name, surname and contact data public (Art. 4 quáter.4, Annex IV)."@en .

