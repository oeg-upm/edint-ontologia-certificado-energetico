# =============================================================================
# DATATYPE PROPERTIES — EnergyRating
# =============================================================================

edintcee:ratingLetter a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "letra de calificación"@es ;
    rdfs:label "rating letter"@en ;
    rdfs:domain edintcee:EnergyRating ;
    rdfs:range [
        a owl:Class ;
        owl:intersectionOf (
            skos:Concept
            [ a owl:Restriction ;
              owl:onProperty skos:inScheme ;
              owl:hasValue edintkos:RatingLetter
            ]
        )
    ] ;
    rdfs:comment "Letra de la calificación global de eficiencia energética en la escala A-G, según el vocabulario controlado de letras de calificación."@es ;
    rdfs:comment "Global energy efficiency rating letter on the A-G scale, according to the rating-letter controlled vocabulary."@en .

edintcee:primaryEnergyTotal a owl:ObjectProperty ;
    rdfs:label "energía primaria total"@es ;
    rdfs:label "total primary energy"@en ;
    rdfs:domain edintcee:EnergyRating ;
    rdfs:range qudt:QuantityValue ;
    rdfs:comment "Energía primaria total. Se expresa como qudt:QuantityValue, típicamente en kWh/m²·año."@es ;
    rdfs:comment "Total primary energy. Expressed as qudt:QuantityValue, typically in kWh/m²·year."@en .

edintcee:primaryEnergyNonRenewable a owl:ObjectProperty ;
    rdfs:label "energía primaria no renovable"@es ;
    rdfs:label "non-renewable primary energy"@en ;
    rdfs:domain edintcee:EnergyRating ;
    rdfs:range qudt:QuantityValue ;
    rdfs:comment "Energía primaria no renovable. Se expresa como qudt:QuantityValue, típicamente en kWh/m²·año."@es ;
    rdfs:comment "Non-renewable primary energy. Expressed as qudt:QuantityValue, typically in kWh/m²·year."@en .

edintcee:primaryEnergyRenewable a owl:ObjectProperty ;
    rdfs:label "energía primaria renovable"@es ;
    rdfs:label "renewable primary energy"@en ;
    rdfs:domain edintcee:EnergyRating ;
    rdfs:range qudt:QuantityValue ;
    rdfs:comment "Energía primaria renovable. Se expresa como qudt:QuantityValue, típicamente en kWh/m²·año."@es ;
    rdfs:comment "Renewable primary energy. Expressed as qudt:QuantityValue, typically in kWh/m²·year."@en .

edintcee:co2Emissions a owl:ObjectProperty ;
    rdfs:label "emisiones de CO2"@es ;
    rdfs:label "CO2 emissions"@en ;
    rdfs:domain edintcee:EnergyRating ;
    rdfs:range qudt:QuantityValue ;
    rdfs:comment "Emisiones de CO2. Se expresa como qudt:QuantityValue, típicamente en kgCO2/m²·año."@es ;
