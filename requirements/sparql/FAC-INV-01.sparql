# FAC-INV-01: Las propiedades inversas son consistentes con las directas
# Verifica que hasRating‚ÜîratingOf, issuedBy‚ÜîissuedCertificate, etc.

PREFIX edintcee: <http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/>

SELECT ?cert ?property ?value
WHERE {
    ?cert a edintcee:EnergyCertificate .
    {
        ?cert edintcee:hasRating ?value .
        FILTER NOT EXISTS { ?value edintcee:ratingOf ?cert }
        BIND ("hasRating‚ÜîratingOf" AS ?property)
    } UNION {
        ?cert edintcee:issuedBy ?value .
        FILTER NOT EXISTS { ?value edintcee:issuedCertificate ?cert }
        BIND ("issuedBy‚ÜîissuedCertificate" AS ?property)
    } UNION {
        ?cert edintcee:hasLabel ?value .
        FILTER NOT EXISTS { ?value edintcee:labelFor ?cert }
        BIND ("hasLabel‚ÜîlabelFor" AS ?property)
    } UNION {
        ?cert edintcee:hasRecommendation ?value .
        FILTER NOT EXISTS { ?value edintcee:recommendationFor ?cert }
        BIND ("hasRecommendation‚ÜîrecommendationFor" AS ?property)
    } UNION {
        ?cert edintcee:usesProcedure ?value .
        FILTER NOT EXISTS { ?value edintcee:procedureUsedBy ?cert }
        BIND ("usesProcedure‚ÜîprocedureUsedBy" AS ?property)
    } UNION {
        ?cert edintcee:predecessorCertificate ?value .
        FILTER NOT EXISTS { ?value edintcee:successorCertificate ?cert }
        BIND ("predecessorCertificate‚ÜîsuccessorCertificate" AS ?property)
    }
}
