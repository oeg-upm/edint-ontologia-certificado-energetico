# FAC-CERT-01: Un certificado tiene exactamente una calificación energética
# Debe fallar si un certificado no tiene rating o tiene más de uno

PREFIX edintcee: <http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/>

SELECT ?cert (COUNT(?rating) AS ?ratingCount)
WHERE {
    ?cert a edintcee:EnergyCertificate .
    OPTIONAL { ?cert edintcee:hasRating ?rating }
}
GROUP BY ?cert
HAVING (COUNT(?rating) != 1)
