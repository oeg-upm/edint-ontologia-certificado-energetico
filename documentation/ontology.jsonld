  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Autonomous community"
  }, {
    "@language" : "es",
    "@value" : "Autonomía"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/abstract" : [ {
    "@language" : "en",
    "@value" : "Ontology focused on the energy performance certificate as a documentary unit, including energy rating, label, competent technician, improvement recommendations, calculation procedure and user recommendations."
  }, {
    "@language" : "es",
    "@value" : "Ontología centrada en el certificado de eficiencia energética como unidad documental, incluyendo calificación energética, etiqueta, técnico competente, recomendaciones de mejora, procedimiento de cálculo y recomendaciones de uso para el usuario."
  } ],
  "http://purl.org/dc/terms/created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-05-14"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "Daniel Doña"
  }, {
    "@value" : "Edna Ruckhaus"
  }, {
    "@value" : "FEMP"
  }, {
    "@value" : "Lucía Sánchez"
  }, {
    "@value" : "Maria del Socorro Bernardos"
  }, {
    "@value" : "Oscar Corcho"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "An ontology modelling energy performance certificates for buildings according to Spanish Royal Decree 390/2021. The root class is EnergyCertificate; the building is an external entity that points to the certificate via a property defined in its own ontology."
  }, {
    "@language" : "es",
    "@value" : "Ontología que modela los certificados de eficiencia energética de edificios según el Real Decreto 390/2021. La clase raíz es EnergyCertificate; el edificio es una entidad externa que apunta al certificado mediante una propiedad definida en su propia ontología."
  } ],
  "http://purl.org/dc/terms/hasFormat" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/ontology.ttl"
  } ],
  "http://purl.org/dc/terms/issued" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-05-14"
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/modified" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-05-14"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "en",
    "@value" : "Energy Performance Certificate Ontology for Buildings"
  }, {
    "@language" : "es",
    "@value" : "Ontología de Certificados de Eficiencia Energética de Edificios"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@value" : "edintcee"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@value" : "http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Initial (core) version focusing on the main classes: EnergyCertificate, EnergyRating, EnergyLabel, CompetentTechnician, ImprovementRecommendation, CalculationProcedure and UserRecommendations, with their relationships and properties."
  }, {
    "@language" : "es",
    "@value" : "Versión inicial (core) centrada en las clases principales: EnergyCertificate, EnergyRating, EnergyLabel, CompetentTechnician, ImprovementRecommendation, CalculationProcedure y UserRecommendations, con sus relaciones y propiedades."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://www.boe.es/eli/es/rd/2021/06/01/390"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/0.1.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "0.1.0"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/CalculationProcedure",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Procedimiento reconocido (general o simplificado) inscrito en el Registro general de documentos reconocidos, utilizado para obtener la calificación de eficiencia energética (Art. 4.2.a, Art. 5)."
  }, {
    "@language" : "en",
    "@value" : "Recognised procedure (general or simplified) registered in the general registry of recognised documents, used to obtain the energy performance rating (Art. 4.2.a, Art. 5)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Calculation procedure"
  }, {
    "@language" : "es",
    "@value" : "Procedimiento de cálculo"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/CompetentTechnician",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Technician qualified to carry out energy performance certification of buildings (Art. 4 bis)."
  }, {
    "@language" : "es",
    "@value" : "Técnico habilitado para realizar la certificación de eficiencia energética de edificios (Art. 4 bis)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Competent technician"
  }, {
    "@language" : "es",
    "@value" : "Técnico competente"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyCertificate",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Documentación suscrita por un técnico competente que contiene la calificación de eficiencia energética de un edificio o parte del mismo, sus características energéticas y recomendaciones de mejora (Art. 2.e-g, RD 390/2021)."
  }, {
    "@language" : "en",
    "@value" : "Documentation signed by a competent technician containing the energy performance rating of a building or part thereof, its energy characteristics and improvement recommendations (Art. 2.e-g, RD 390/2021)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Certificado de eficiencia energética"
  }, {
    "@language" : "en",
    "@value" : "Energy performance certificate"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid73"
  }, {
    "@id" : "_:genid74"
  }, {
    "@id" : "_:genid75"
  }, {
    "@id" : "_:genid76"
  }, {
    "@id" : "_:genid77"
  }, {
    "@id" : "_:genid78"
  }, {
    "@id" : "_:genid79"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyLabel",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Distinctive mark associated with a registered certificate that publicly attests to the energy rating obtained (Art. 2.ñ, Art. 15)."
  }, {
    "@language" : "es",
    "@value" : "Distintivo asociado a un certificado registrado que acredita públicamente la calificación energética obtenida (Art. 2.ñ, Art. 15)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Energy label"
  }, {
    "@language" : "es",
    "@value" : "Etiqueta de eficiencia energética"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyRating",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Expresión de la eficiencia energética de un edificio mediante indicadores numéricos de consumo y emisiones, resumida en una letra de la escala A-G (Art. 2.a)."
  }, {
    "@language" : "en",
    "@value" : "Expression of the energy efficiency of a building through numerical consumption and emission indicators, summarised as a letter on the A-G scale (Art. 2.a)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Calificación energética"
  }, {
    "@language" : "en",
    "@value" : "Energy rating"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid80"
  }, {
    "@id" : "_:genid81"
  }, {
    "@id" : "_:genid82"
  }, {
    "@id" : "_:genid83"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/ImprovementRecommendation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Intervención técnicamente viable para la mejora de los niveles óptimos o rentables de la eficiencia energética, incluyendo estimación de costes y plazos de recuperación (Art. 8.2.f)."
  }, {
    "@language" : "en",
    "@value" : "Technically viable intervention for improving optimal or cost-effective energy efficiency levels, including cost estimates and payback periods (Art. 8.2.f)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Improvement recommendation"
  }, {
    "@language" : "es",
    "@value" : "Recomendación de mejora"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/UserRecommendations",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Document with recommendations for the building user/tenant on how to use the building and its systems to achieve optimal energy efficiency (Art. 8.1.f)."
  }, {
    "@language" : "es",
    "@value" : "Documento con recomendaciones para el usuario/arrendatario del edificio sobre cómo utilizar el edificio y sus sistemas para lograr la máxima eficiencia energética (Art. 8.1.f)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Recomendaciones de uso para el usuario"
  }, {
    "@language" : "en",
    "@value" : "User recommendations"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/aggregatedDataAvailableForResearch",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Aggregated and anonymized data are available for statistical and research use (Art. 6.7)."
  }, {
    "@language" : "es",
    "@value" : "Los datos agregados y anonimizados están disponibles para uso estadístico y de investigación (Art. 6.7)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyCertificate"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "aggregated data available for research"
  }, {
    "@language" : "es",
    "@value" : "datos agregados disponibles para investigación"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
