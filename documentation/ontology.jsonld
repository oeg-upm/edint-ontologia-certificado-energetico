    "@language" : "en",
    "@value" : "Cadastral property"
  }, {
    "@language" : "es",
    "@value" : "Inmueble catastral"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Autonomia",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Autonomous Community or Autonomous City in the Spanish territory."
  }, {
    "@language" : "es",
    "@value" : "Comunidad Autónoma o Ciudad Autónoma del territorio español."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
