@prefix : <http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/> .

<http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/> rdf:type owl:Ontology ;
                                                                   owl:versionIRI <http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/0.1.0> ;
                                                                   <http://purl.org/dc/terms/abstract> "Ontology focused on the energy performance certificate as a documentary unit, including energy rating, label, competent technician, improvement recommendations, calculation procedure and user recommendations."@en ,
                                                                                                       "Ontología centrada en el certificado de eficiencia energética como unidad documental, incluyendo calificación energética, etiqueta, técnico competente, recomendaciones de mejora, procedimiento de cálculo y recomendaciones de uso para el usuario."@es ;
                                                                   <http://purl.org/dc/terms/created> "2026-05-14"^^xsd:date ;
                                                                   <http://purl.org/dc/terms/creator> "Daniel Doña" ,
                                                                                                      "Edna Ruckhaus" ,
                                                                                                      "FEMP" ,
                                                                                                      "Lucía Sánchez" ,
                                                                                                      "Maria del Socorro Bernardos" ,
                                                                                                      "Oscar Corcho" ;
                                                                   <http://purl.org/dc/terms/description> "An ontology modelling energy performance certificates for buildings according to Spanish Royal Decree 390/2021. The root class is EnergyCertificate; the building is an external entity that points to the certificate via a property defined in its own ontology."@en ,
                                                                                                          "Ontología que modela los certificados de eficiencia energética de edificios según el Real Decreto 390/2021. La clase raíz es EnergyCertificate; el edificio es una entidad externa que apunta al certificado mediante una propiedad definida en su propia ontología."@es ;
                                                                   <http://purl.org/dc/terms/hasFormat> :ontology.ttl ;
                                                                   <http://purl.org/dc/terms/issued> "2026-05-14"^^xsd:date ;
                                                                   <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                                                   <http://purl.org/dc/terms/modified> "2026-05-14"^^xsd:date ;
                                                                   <http://purl.org/dc/terms/title> "Energy Performance Certificate Ontology for Buildings"@en ,
                                                                                                    "Ontología de Certificados de Eficiencia Energética de Edificios"@es ;
                                                                   <http://purl.org/vocab/vann/preferredNamespacePrefix> "edintcee" ;
                                                                   <http://purl.org/vocab/vann/preferredNamespaceUri> "http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/" ;
                                                                   rdfs:comment "Initial (core) version focusing on the main classes: EnergyCertificate, EnergyRating, EnergyLabel, CompetentTechnician, ImprovementRecommendation, CalculationProcedure and UserRecommendations, with their relationships and properties."@en ,
                                                                                "Versión inicial (core) centrada en las clases principales: EnergyCertificate, EnergyRating, EnergyLabel, CompetentTechnician, ImprovementRecommendation, CalculationProcedure y UserRecommendations, con sus relaciones y propiedades."@es ;
                                                                   rdfs:seeAlso <https://www.boe.es/eli/es/rd/2021/06/01/390> ;
                                                                   owl:versionInfo "0.1.0" .

