xsd:gYear rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/coolingEnergySource
:coolingEnergySource rdf:type owl:ObjectProperty ;
                     rdfs:domain :EnergyCertificate ;
                     rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                         owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/energy-source/EnergySources>
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                     rdfs:comment "Energy source of the cooling system according to the energy-source controlled vocabulary."@en ,
                                  "Fuente de energía del sistema de refrigeración según el vocabulario controlado de fuentes de energía."@es ;
                     rdfs:label "cooling energy source"@en ,
                                "fuente energética de refrigeración"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/dhwEnergySource
:dhwEnergySource rdf:type owl:ObjectProperty ;
                 rdfs:domain :EnergyCertificate ;
                 rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                     owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/energy-source/EnergySources>
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
                 rdfs:comment "Energy source of the domestic hot water system according to the energy-source controlled vocabulary."@en ,
                              "Fuente de energía del sistema de agua caliente sanitaria según el vocabulario controlado de fuentes de energía."@es ;
                 rdfs:label "DHW energy source"@en ,
                            "fuente energética de ACS"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/hasLabel
:hasLabel rdf:type owl:ObjectProperty ;
          owl:inverseOf :labelFor ;
          rdfs:domain :EnergyCertificate ;
          rdfs:range :EnergyLabel ;
          rdfs:comment "Energy label associated with the registered certificate."@en ,
                       "Etiqueta de eficiencia energética asociada al certificado registrado."@es ;
          rdfs:label "has label"@en ,
                     "tiene etiqueta"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/hasRating
:hasRating rdf:type owl:ObjectProperty ;
           owl:inverseOf :ratingOf ;
           rdfs:domain :EnergyCertificate ;
           rdfs:range :EnergyRating ;
           rdfs:comment "Links a certificate to its energy rating indicators."@en ,
                        "Vincula un certificado a sus indicadores de calificación energética."@es ;
           rdfs:label "has rating"@en ,
                      "tiene calificación"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/hasRecommendation
:hasRecommendation rdf:type owl:ObjectProperty ;
                   owl:inverseOf :recommendationFor ;
                   rdfs:domain :EnergyCertificate ;
                   rdfs:range :ImprovementRecommendation ;
                   rdfs:comment "Improvement recommendation included in the certificate."@en ,
                                "Recomendación de mejora incluida en el certificado."@es ;
                   rdfs:label "has recommendation"@en ,
                              "tiene recomendación"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/hasUserRecommendations
:hasUserRecommendations rdf:type owl:ObjectProperty ;
                        rdfs:domain :EnergyCertificate ;
                        rdfs:range :UserRecommendations ;
                        rdfs:comment "Documento de recomendaciones de uso entregado al usuario/arrendatario del edificio (Art. 8.1.f)."@es ,
                                     "User recommendations document delivered to the building user/tenant (Art. 8.1.f)."@en ;
                        rdfs:label "has user recommendations"@en ,
                                   "tiene recomendaciones de uso"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/heatingEnergySource
:heatingEnergySource rdf:type owl:ObjectProperty ;
                     rdfs:domain :EnergyCertificate ;
                     rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                         owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/energy-source/EnergySources>
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                     rdfs:comment "Energy source of the heating system according to the energy-source controlled vocabulary."@en ,
                                  "Fuente de energía del sistema de calefacción según el vocabulario controlado de fuentes de energía."@es ;
                     rdfs:label "fuente energética de calefacción"@es ,
                                "heating energy source"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/issuedBy
:issuedBy rdf:type owl:ObjectProperty ;
          owl:inverseOf :issuedCertificate ;
          rdfs:domain :EnergyCertificate ;
          rdfs:range :CompetentTechnician ;
          rdfs:comment "Competent technician who signs the certificate."@en ,
                       "Técnico competente que suscribe el certificado."@es ;
          rdfs:label "emitido por"@es ,
                     "issued by"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/issuedCertificate
:issuedCertificate rdf:type owl:ObjectProperty ;
                   rdfs:domain :CompetentTechnician ;
                   rdfs:range :EnergyCertificate ;
                   rdfs:comment "Certificado emitido por este técnico."@es ,
                                "Certificate issued by this technician."@en ;
                   rdfs:label "certificado emitido"@es ,
                              "issued certificate"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/labelFor
:labelFor rdf:type owl:ObjectProperty ;
          rdfs:domain :EnergyLabel ;
          rdfs:range :EnergyCertificate ;
          rdfs:comment "Certificado al que corresponde esta etiqueta."@es ,
                       "Certificate this label belongs to."@en ;
          rdfs:label "etiqueta para"@es ,
                     "label for"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/observedBuildingUse
:observedBuildingUse rdf:type owl:ObjectProperty ;
                     rdfs:domain :EnergyCertificate ;
                     rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                         owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/building-use/BuildingUses>
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                     rdfs:comment "Building use according to the building-use controlled vocabulary."@en ,
                                  "Uso del edificio según el vocabulario controlado de usos de edificio."@es ;
                     rdfs:label "observed building use"@en ,
                                "uso del edificio observado"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/observedClimaticZone
:observedClimaticZone rdf:type owl:ObjectProperty ;
                      rdfs:domain :EnergyCertificate ;
                      rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                          owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/climatic-zone/ClimaticZones>
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
                      rdfs:comment "Climatic zone according to the climatic-zone controlled vocabulary."@en ,
                                   "Zona climática según el vocabulario controlado de zonas climáticas."@es ;
                      rdfs:label "observed climatic zone"@en ,
                                 "zona climática observada"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/predecessorCertificate
:predecessorCertificate rdf:type owl:ObjectProperty ;
                        owl:inverseOf :successorCertificate ;
                        rdfs:domain :EnergyCertificate ;
                        rdfs:range :EnergyCertificate ;
                        rdfs:comment "Certificado anterior que este certificado renueva o reemplaza."@es ,
                                     "Previous certificate that this certificate renews or replaces."@en ;
                        rdfs:label "certificado anterior"@es ,
                                   "predecessor certificate"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/procedureUsedBy
:procedureUsedBy rdf:type owl:ObjectProperty ;
                 rdfs:domain :CalculationProcedure ;
                 rdfs:range :EnergyCertificate ;
                 rdfs:comment "Certificado que utiliza este procedimiento."@es ,
                              "Certificate that uses this procedure."@en ;
                 rdfs:label "procedimiento usado por"@es ,
                            "procedure used by"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/ratingOf
:ratingOf rdf:type owl:ObjectProperty ;
          rdfs:domain :EnergyRating ;
          rdfs:range :EnergyCertificate ;
          rdfs:comment "Certificado al que pertenece esta calificación."@es ,
                       "Certificate this rating belongs to."@en ;
          rdfs:label "calificación de"@es ,
                     "rating of"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/recommendationFor
:recommendationFor rdf:type owl:ObjectProperty ;
                   rdfs:domain :ImprovementRecommendation ;
                   rdfs:range :EnergyCertificate ;
                   rdfs:comment "Certificado al que pertenece esta recomendación."@es ,
                                "Certificate this recommendation belongs to."@en ;
                   rdfs:label "recomendación para"@es ,
                              "recommendation for"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/renewableEnergySource
:renewableEnergySource rdf:type owl:ObjectProperty ;
                       rdfs:domain :EnergyCertificate ;
                       rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                           owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/energy-source/EnergySources>
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
                       rdfs:comment "Tipo de fuente de energía renovable según el vocabulario controlado de fuentes de energía."@es ,
                                    "Type of renewable energy source according to the energy-source controlled vocabulary."@en ;
                       rdfs:label "fuente de energía renovable"@es ,
                                  "renewable energy source"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/successorCertificate
:successorCertificate rdf:type owl:ObjectProperty ;
                      rdfs:domain :EnergyCertificate ;
                      rdfs:range :EnergyCertificate ;
                      rdfs:comment "Certificado que reemplaza o renueva este certificado."@es ,
                                   "Certificate that renews or replaces this certificate."@en ;
                      rdfs:label "certificado sucesor"@es ,
                                 "successor certificate"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/usesProcedure
:usesProcedure rdf:type owl:ObjectProperty ;
               owl:inverseOf :procedureUsedBy ;
               rdfs:domain :EnergyCertificate ;
               rdfs:range :CalculationProcedure ;
               rdfs:comment "Procedimiento de cálculo reconocido utilizado para obtener la calificación."@es ,
                            "Recognised calculation procedure used to obtain the rating."@en ;
               rdfs:label "usa procedimiento"@es ,
                          "uses procedure"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/ventilationEnergySource
:ventilationEnergySource rdf:type owl:ObjectProperty ;
                         rdfs:domain :EnergyCertificate ;
                         rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                             owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/energy-source/EnergySources>
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                         rdfs:comment "Energy source of the ventilation system according to the energy-source controlled vocabulary."@en ,
                                      "Fuente de energía del sistema de ventilación según el vocabulario controlado de fuentes de energía."@es ;
                         rdfs:label "fuente energética de ventilación"@es ,
                                    "ventilation energy source"@en .


###  http://www.w3.org/2004/02/skos/core#inScheme
<http://www.w3.org/2004/02/skos/core#inScheme> rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/aggregatedDataAvailableForResearch
:aggregatedDataAvailableForResearch rdf:type owl:DatatypeProperty ;
                                    rdfs:domain :EnergyCertificate ;
                                    rdfs:range xsd:boolean ;
                                    rdfs:comment "Aggregated and anonymized data are available for statistical and research use (Art. 6.7)."@en ,
                                                 "Los datos agregados y anonimizados están disponibles para uso estadístico y de investigación (Art. 6.7)."@es ;
                                    rdfs:label "aggregated data available for research"@en ,
                                               "datos agregados disponibles para investigación"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/applicableRegulation
:applicableRegulation rdf:type owl:DatatypeProperty ;
                      rdfs:domain :EnergyCertificate ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Normativa aplicada en la evaluación (Art. 8.2.c)."@es ,
                                   "Regulation applied in the evaluation (Art. 8.2.c)."@en ;
                      rdfs:label "applicable regulation"@en ,
                                 "normativa aplicable"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/architecturalProtectionType
:architecturalProtectionType rdf:type owl:DatatypeProperty ;
                             rdfs:domain :EnergyCertificate ;
                             rdfs:range xsd:string ;
                             rdfs:comment "Tipo y nivel de catalogación arquitectónica (ej: 'Bien de Interés Cultural', 'Protegido por PGOU')."@es ,
                                          "Type and level of architectural catalogation/protection."@en ;
                             rdfs:label "architectural protection type"@en ,
                                        "tipo de protección arquitectónica"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/calculationDocumentsReference
:calculationDocumentsReference rdf:type owl:DatatypeProperty ;
                               rdfs:domain :EnergyCertificate ;
                               rdfs:range xsd:anyURI ;
                               rdfs:comment "Reference to documents or digital files needed for the evaluation (Art. 8.1.d)."@en ,
                                            "Referencia a documentos o ficheros digitales necesarios para la evaluación (Art. 8.1.d)."@es ;
                               rdfs:label "calculation documents reference"@en ,
                                          "referencia a documentos de cálculo"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/certificateHash
:certificateHash rdf:type owl:DatatypeProperty ;
                 rdfs:domain :EnergyCertificate ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Cryptographic hash of the certificate for integrity verification."@en ,
                              "Hash criptográfico del certificado para verificación de integridad."@es ;
                 rdfs:label "certificate hash"@en ,
                            "hash del certificado"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/certificateNumber
:certificateNumber rdf:type owl:DatatypeProperty ;
                   rdfs:domain :EnergyCertificate ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Certificate registration number in the autonomous community (Art. 6.6)."@en ,
                                "Número de registro del certificado en la comunidad autónoma (Art. 6.6)."@es ;
                   rdfs:label "certificate number"@en ,
                              "número de certificado"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/co2Emissions
:co2Emissions rdf:type owl:DatatypeProperty ;
              rdfs:domain :EnergyRating ;
              rdfs:range xsd:decimal ;
              rdfs:label "CO2 emissions (kgCO2/m²·year)"@en ,
                         "emisiones de CO2 (kgCO2/m²·año)"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/comfortConditions
:comfortConditions rdf:type owl:DatatypeProperty ;
                   rdfs:domain :EnergyCertificate ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Comfort conditions considered in the energy evaluation (Art. 8.2.d)."@en ,
                                "Condiciones de confort consideradas en la evaluación energética (Art. 8.2.d)."@es ;
                   rdfs:label "comfort conditions"@en ,
                              "condiciones de confort"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/comfortHealthBenefit
:comfortHealthBenefit rdf:type owl:DatatypeProperty ;
                      rdfs:domain :ImprovementRecommendation ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Comfort, health or well-being improvements derived from implementation (Art. 8.2.f)."@en ,
                                   "Mejoras en confort, salud o bienestar derivadas de la implementación (Art. 8.2.f)."@es ;
                      rdfs:label "beneficio en confort/salud"@es ,
                                 "comfort/health benefit"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/consumptionDataAvailableToOwner
:consumptionDataAvailableToOwner rdf:type owl:DatatypeProperty ;
                                 rdfs:domain :EnergyCertificate ;
                                 rdfs:range xsd:boolean ;
                                 rdfs:comment "Consumption data is available to the building owner (Art. 6.7)."@en ,
                                              "Los datos de consumo están disponibles para el propietario del edificio (Art. 6.7)."@es ;
                                 rdfs:label "consumption data available to owner"@en ,
                                            "datos de consumo disponibles para el propietario"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/coolingConsumption
:coolingConsumption rdf:type owl:DatatypeProperty ;
                    rdfs:domain :EnergyRating ;
                    rdfs:range xsd:decimal ;
                    rdfs:label "consumo de refrigeración (kWh/m²·año)"@es ,
                               "cooling consumption (kWh/m²·year)"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/coolingDemand
:coolingDemand rdf:type owl:DatatypeProperty ;
               rdfs:domain :EnergyRating ;
               rdfs:range xsd:decimal ;
               rdfs:label "cooling demand (kWh/m²·year)"@en ,
