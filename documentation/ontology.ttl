###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/CompetentTechnician
:CompetentTechnician rdf:type owl:Class ;
                     rdfs:comment "Technician qualified to carry out energy performance certification of buildings (Art. 4 bis)."@en ,
                                  "Técnico habilitado para realizar la certificación de eficiencia energética de edificios (Art. 4 bis)."@es ;
                     rdfs:label "Competent technician"@en ,
                                "Técnico competente"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyCertificate
:EnergyCertificate rdf:type owl:Class ;
                   rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasUserRecommendations ;
                                     owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onClass :UserRecommendations
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :certificateType ;
                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onClass <http://www.w3.org/2004/02/skos/core#Concept>
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasRating ;
                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onClass :EnergyRating
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :issuedBy ;
                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onClass :CompetentTechnician
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :usesProcedure ;
                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onClass :CalculationProcedure
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :issueDate ;
                                     owl:cardinality "1"^^xsd:nonNegativeInteger
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :validUntil ;
                                     owl:cardinality "1"^^xsd:nonNegativeInteger
                                   ] ;
                   rdfs:comment "Documentación suscrita por un técnico competente que contiene la calificación de eficiencia energética de un edificio o parte del mismo, sus características energéticas y recomendaciones de mejora (Art. 2.e-g, RD 390/2021)."@es ,
                                "Documentation signed by a competent technician containing the energy performance rating of a building or part thereof, its energy characteristics and improvement recommendations (Art. 2.e-g, RD 390/2021)."@en ;
                   rdfs:label "Certificado de eficiencia energética"@es ,
                              "Energy performance certificate"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyLabel
:EnergyLabel rdf:type owl:Class ;
             rdfs:comment "Distinctive mark associated with a registered certificate that publicly attests to the energy rating obtained (Art. 2.ñ, Art. 15)."@en ,
                          "Distintivo asociado a un certificado registrado que acredita públicamente la calificación energética obtenida (Art. 2.ñ, Art. 15)."@es ;
             rdfs:label "Energy label"@en ,
                        "Etiqueta de eficiencia energética"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyRating
:EnergyRating rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :co2Emissions ;
                                owl:cardinality "1"^^xsd:nonNegativeInteger
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :primaryEnergyNonRenewable ;
                                owl:cardinality "1"^^xsd:nonNegativeInteger
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :ratingLetter ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass <http://www.w3.org/2004/02/skos/core#Concept>
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :ratingScaleVersion ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass <http://www.w3.org/2004/02/skos/core#Concept>
                              ] ;
              rdfs:comment "Expresión de la eficiencia energética de un edificio mediante indicadores numéricos de consumo y emisiones, resumida en una letra de la escala A-G (Art. 2.a)."@es ,
                           "Expression of the energy efficiency of a building through numerical consumption and emission indicators, summarised as a letter on the A-G scale (Art. 2.a)."@en ;
              rdfs:label "Calificación energética"@es ,
                         "Energy rating"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/ImprovementRecommendation
:ImprovementRecommendation rdf:type owl:Class ;
                           rdfs:comment "Intervención técnicamente viable para la mejora de los niveles óptimos o rentables de la eficiencia energética, incluyendo estimación de costes y plazos de recuperación (Art. 8.2.f)."@es ,
                                        "Technically viable intervention for improving optimal or cost-effective energy efficiency levels, including cost estimates and payback periods (Art. 8.2.f)."@en ;
                           rdfs:label "Improvement recommendation"@en ,
                                      "Recomendación de mejora"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/UserRecommendations
:UserRecommendations rdf:type owl:Class ;
                     rdfs:comment "Document with recommendations for the building user/tenant on how to use the building and its systems to achieve optimal energy efficiency (Art. 8.1.f)."@en ,
                                  "Documento con recomendaciones para el usuario/arrendatario del edificio sobre cómo utilizar el edificio y sus sistemas para lograr la máxima eficiencia energética (Art. 8.1.f)."@es ;
                     rdfs:label "Recomendaciones de uso para el usuario"@es ,
                                "User recommendations"@en .


