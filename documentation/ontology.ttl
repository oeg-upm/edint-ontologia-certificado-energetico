@prefix : <http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/> .

<http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/> rdf:type owl:Ontology ;
                                                                   owl:versionIRI <http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/0.1.0> ;
                                                                   <http://purl.org/dc/terms/abstract> "Ontology focused on the energy performance certificate as a documentary unit, including energy rating, label, competent technician, improvement recommendations, calculation procedure and user recommendations."@en ,
                                                                                                       "Ontología centrada en el certificado de eficiencia energética como unidad documental, incluyendo calificación energética, etiqueta, técnico competente, recomendaciones de mejora, procedimiento de cálculo y recomendaciones de uso para el usuario."@es ;
                                                                   <http://purl.org/dc/terms/created> "2026-05-14"^^xsd:date ;
                                                                   <http://purl.org/dc/terms/creator> "Daniel Doña" ,
                                                                                                      "Edna Ruckhaus" ,
                                                                                                      "FEMP" ,
                                                                                                      "Lucía Sánchez" ,
                                                                                                      "Maria del Socorro Bernardos" ,
                                                                                                      "Oscar Corcho" ;
                                                                   <http://purl.org/dc/terms/description> "An ontology modelling energy performance certificates for buildings according to Spanish Royal Decree 390/2021. The root class is EnergyCertificate; the building is an external entity that points to the certificate via a property defined in its own ontology."@en ,
                                                                                                          "Ontología que modela los certificados de eficiencia energética de edificios según el Real Decreto 390/2021. La clase raíz es EnergyCertificate; el edificio es una entidad externa que apunta al certificado mediante una propiedad definida en su propia ontología."@es ;
                                                                   <http://purl.org/dc/terms/hasFormat> :ontology.ttl ;
                                                                   <http://purl.org/dc/terms/issued> "2026-05-14"^^xsd:date ;
                                                                   <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                                                   <http://purl.org/dc/terms/modified> "2026-05-14"^^xsd:date ;
                                                                   <http://purl.org/dc/terms/title> "Energy Performance Certificate Ontology for Buildings"@en ,
                                                                                                    "Ontología de Certificados de Eficiencia Energética de Edificios"@es ;
                                                                   <http://purl.org/vocab/vann/preferredNamespacePrefix> "edintcee" ;
                                                                   <http://purl.org/vocab/vann/preferredNamespaceUri> "http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/" ;
                                                                   rdfs:comment "Initial (core) version focusing on the main classes: EnergyCertificate, EnergyRating, EnergyLabel, CompetentTechnician, ImprovementRecommendation, CalculationProcedure and UserRecommendations, with their relationships and properties."@en ,
                                                                                "Versión inicial (core) centrada en las clases principales: EnergyCertificate, EnergyRating, EnergyLabel, CompetentTechnician, ImprovementRecommendation, CalculationProcedure y UserRecommendations, con sus relaciones y propiedades."@es ;
                                                                   rdfs:seeAlso <https://www.boe.es/eli/es/rd/2021/06/01/390> ;
                                                                   owl:versionInfo "0.1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/abstract
<http://purl.org/dc/terms/abstract> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/hasFormat
<http://purl.org/dc/terms/hasFormat> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/issued
<http://purl.org/dc/terms/issued> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
<http://purl.org/dc/terms/modified> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/certificateType
:certificateType rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :EnergyCertificate ;
                 rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                     owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/CertificateType>
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
                 rdfs:comment "Tipo de certificado de eficiencia energética según el vocabulario controlado de tipos de certificado: proyecto, obra terminada o edificio existente (Art. 2.b-g, Art. 9-10, Art. 15.2 RD 390/2021)."@es ,
                              "Type of energy performance certificate according to the certificate-type controlled vocabulary: project, completed work or existing building (Art. 2.b-g, Art. 9-10, Art. 15.2 RD 390/2021)."@en ;
                 rdfs:label "certificate type"@en ,
                            "tipo de certificado"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/co2Emissions
:co2Emissions rdf:type owl:ObjectProperty ;
              rdfs:domain :EnergyRating ;
              rdfs:range <http://qudt.org/schema/qudt/QuantityValue> ;
              rdfs:comment "CO2 emissions. Expressed as qudt:QuantityValue, typically in kgCO2/m²·year."@en ,
                           "Emisiones de CO2. Se expresa como qudt:QuantityValue, típicamente en kgCO2/m²·año."@es ;
              rdfs:label "CO2 emissions"@en ,
                         "emisiones de CO2"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/coolingConsumption
:coolingConsumption rdf:type owl:ObjectProperty ;
                    rdfs:domain :EnergyRating ;
                    rdfs:range <http://qudt.org/schema/qudt/QuantityValue> ;
                    rdfs:comment "Consumo de refrigeración. Se expresa como qudt:QuantityValue, típicamente en kWh/m²·año."@es ,
                                 "Cooling consumption. Expressed as qudt:QuantityValue, typically in kWh/m²·year."@en ;
                    rdfs:label "consumo de refrigeración"@es ,
                               "cooling consumption"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/coolingDemand
:coolingDemand rdf:type owl:ObjectProperty ;
               rdfs:domain :EnergyRating ;
               rdfs:range <http://qudt.org/schema/qudt/QuantityValue> ;
               rdfs:comment "Cooling demand. Expressed as qudt:QuantityValue, typically in kWh/m²·year."@en ,
                            "Demanda de refrigeración. Se expresa como qudt:QuantityValue, típicamente en kWh/m²·año."@es ;
               rdfs:label "cooling demand"@en ,
                          "demanda de refrigeración"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/coolingEfficiency
:coolingEfficiency rdf:type owl:ObjectProperty ;
                   rdfs:domain :EnergyCertificate ;
                   rdfs:range <http://qudt.org/schema/qudt/QuantityValue> ;
                   rdfs:comment "Rendimiento estacional del sistema de refrigeración. Se expresa como qudt:QuantityValue."@es ,
                                "Seasonal efficiency of the cooling system. Expressed as qudt:QuantityValue."@en ;
                   rdfs:label "rendimiento estacional refrigeración"@es ,
                              "seasonal cooling efficiency"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/coolingEnergySource
:coolingEnergySource rdf:type owl:ObjectProperty ;
                     rdfs:domain :EnergyCertificate ;
                     rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                         owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/EnergySource>
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                     rdfs:comment "Energy source of the cooling system according to the energy-source controlled vocabulary."@en ,
                                  "Fuente de energía del sistema de refrigeración según el vocabulario controlado de fuentes de energía."@es ;
                     rdfs:label "cooling energy source"@en ,
                                "fuente energética de refrigeración"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/dataBasis
:dataBasis rdf:type owl:ObjectProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :EnergyRating ;
           rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                               owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/DataBasis>
                                             ]
                                           ) ;
                        rdf:type owl:Class
                      ] ;
           rdfs:comment "Indica si los indicadores se basan en datos medidos, calculados o mixtos, según el vocabulario controlado de tipos de base de datos (Art. 6.7)."@es ,
                        "Indicates whether indicators are based on measured, calculated or mixed data, according to the data-basis controlled vocabulary (Art. 6.7)."@en ;
           rdfs:label "base de datos"@es ,
                      "data basis"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/dhwConsumption
:dhwConsumption rdf:type owl:ObjectProperty ;
                rdfs:domain :EnergyRating ;
                rdfs:range <http://qudt.org/schema/qudt/QuantityValue> ;
                rdfs:comment "Consumo de agua caliente sanitaria. Se expresa como qudt:QuantityValue, típicamente en kWh/m²·año."@es ,
                             "Domestic hot water consumption. Expressed as qudt:QuantityValue, typically in kWh/m²·year."@en ;
                rdfs:label "DHW consumption"@en ,
                           "consumo de ACS"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/dhwDemand
:dhwDemand rdf:type owl:ObjectProperty ;
           rdfs:domain :EnergyRating ;
           rdfs:range <http://qudt.org/schema/qudt/QuantityValue> ;
           rdfs:comment "Demanda de agua caliente sanitaria. Se expresa como qudt:QuantityValue, típicamente en kWh/m²·año."@es ,
                        "Domestic hot water demand. Expressed as qudt:QuantityValue, typically in kWh/m²·year."@en ;
           rdfs:label "DHW demand"@en ,
                      "demanda de ACS"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/dhwEnergySource
:dhwEnergySource rdf:type owl:ObjectProperty ;
                 rdfs:domain :EnergyCertificate ;
                 rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                     owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/EnergySource>
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
                 rdfs:comment "Energy source of the domestic hot water system according to the energy-source controlled vocabulary."@en ,
                              "Fuente de energía del sistema de agua caliente sanitaria según el vocabulario controlado de fuentes de energía."@es ;
                 rdfs:label "DHW energy source"@en ,
                            "fuente energética de ACS"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/envelopeArea
:envelopeArea rdf:type owl:ObjectProperty ;
              rdfs:domain :EnergyCertificate ;
              rdfs:range <http://qudt.org/schema/qudt/QuantityValue> ;
              rdfs:comment "Superficie de la envolvente térmica en contacto con el exterior. Se expresa como qudt:QuantityValue (qudt:numericValue + qudt:hasUnit), típicamente en m²."@es ,
                           "Surface area of the thermal envelope in contact with the exterior. Expressed as qudt:QuantityValue (qudt:numericValue + qudt:hasUnit), typically in m²."@en ;
              rdfs:label "envelope area"@en ,
                         "superficie de envolvente"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/estimatedCost
:estimatedCost rdf:type owl:ObjectProperty ;
               rdfs:domain :ImprovementRecommendation ;
               rdfs:range <http://qudt.org/schema/qudt/QuantityValue> ;
               rdfs:comment "Coste estimado de la intervención. Se expresa como qudt:QuantityValue, típicamente en euros."@es ,
                            "Estimated cost of the intervention. Expressed as qudt:QuantityValue, typically in euros."@en ;
               rdfs:label "coste estimado"@es ,
                          "estimated cost"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/estimatedSavingKwh
:estimatedSavingKwh rdf:type owl:ObjectProperty ;
                    rdfs:domain :ImprovementRecommendation ;
                    rdfs:range <http://qudt.org/schema/qudt/QuantityValue> ;
                    rdfs:comment "Ahorro estimado en energía. Se expresa como qudt:QuantityValue, típicamente en kWh/año."@es ,
                                 "Estimated energy saving. Expressed as qudt:QuantityValue, typically in kWh/year."@en ;
                    rdfs:label "ahorro estimado en energía"@es ,
                               "estimated saving in energy"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/estimatedSavingPct
:estimatedSavingPct rdf:type owl:ObjectProperty ;
                    rdfs:domain :ImprovementRecommendation ;
                    rdfs:range <http://qudt.org/schema/qudt/QuantityValue> ;
                    rdfs:comment "Ahorro estimado porcentual. Se expresa como qudt:QuantityValue, típicamente en porcentaje."@es ,
                                 "Estimated percentage saving. Expressed as qudt:QuantityValue, typically in percent."@en ;
                    rdfs:label "ahorro estimado"@es ,
                               "estimated saving"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/globalHeatTransferCoeff
:globalHeatTransferCoeff rdf:type owl:ObjectProperty ;
                         rdfs:domain :EnergyCertificate ;
                         rdfs:range <http://qudt.org/schema/qudt/QuantityValue> ;
                         rdfs:comment "Coeficiente global de transmitancia térmica U de la envolvente. Se expresa como qudt:QuantityValue, típicamente en W/m²·K."@es ,
                                      "Global thermal transmittance coefficient U of the envelope. Expressed as qudt:QuantityValue, typically in W/m²·K."@en ;
                         rdfs:label "coeficiente global de transmitancia"@es ,
                                    "global heat transfer coefficient"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/hasLabel
:hasLabel rdf:type owl:ObjectProperty ;
          owl:inverseOf :labelFor ;
          rdfs:domain :EnergyCertificate ;
          rdfs:range :EnergyLabel ;
          rdfs:comment "Energy label associated with the registered certificate."@en ,
                       "Etiqueta de eficiencia energética asociada al certificado registrado."@es ;
          rdfs:label "has label"@en ,
                     "tiene etiqueta"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/hasObservedAddress
:hasObservedAddress rdf:type owl:ObjectProperty ;
                    rdfs:domain :EnergyCertificate ;
                    rdfs:range <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal> ;
                    rdfs:comment "Dirección postal del inmueble certificado. Se reutiliza esdir:DireccionPostal, que especializa schema:PostalAddress, vcard:Address y locn:Address, y permite representar vía, municipio, provincia y código postal con propiedades estándar (Art. 8.2.a)."@es ,
                                 "Postal address of the certified property. Reuses esdir:DireccionPostal, which specialises schema:PostalAddress, vcard:Address and locn:Address, and allows representing street, municipality, province and postal code with standard properties (Art. 8.2.a)."@en ;
                    rdfs:label "dirección del inmueble"@es ,
                               "observed address"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/hasRating
:hasRating rdf:type owl:ObjectProperty ;
           owl:inverseOf :ratingOf ;
           rdfs:domain :EnergyCertificate ;
           rdfs:range :EnergyRating ;
           rdfs:comment "Links a certificate to its energy rating indicators."@en ,
                        "Vincula un certificado a sus indicadores de calificación energética."@es ;
           rdfs:label "has rating"@en ,
                      "tiene calificación"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/hasRecommendation
:hasRecommendation rdf:type owl:ObjectProperty ;
                   owl:inverseOf :recommendationFor ;
                   rdfs:domain :EnergyCertificate ;
                   rdfs:range :ImprovementRecommendation ;
                   rdfs:comment "Improvement recommendation included in the certificate."@en ,
                                "Recomendación de mejora incluida en el certificado."@es ;
                   rdfs:label "has recommendation"@en ,
                              "tiene recomendación"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/hasTechnicianAddress
:hasTechnicianAddress rdf:type owl:ObjectProperty ;
                      rdfs:domain :CompetentTechnician ;
                      rdfs:range <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal> ;
                      rdfs:comment "Dirección postal del técnico competente. Se reutiliza esdir:DireccionPostal, que especializa schema:PostalAddress, vcard:Address y locn:Address, y permite representar vía, municipio, provincia y código postal con propiedades estándar (Anexo IV)."@es ,
                                   "Postal address of the competent technician. Reuses esdir:DireccionPostal, which specialises schema:PostalAddress, vcard:Address and locn:Address, and allows representing street, municipality, province and postal code with standard properties (Annex IV)."@en ;
                      rdfs:label "dirección del técnico"@es ,
                                 "technician address"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/hasUserRecommendations
:hasUserRecommendations rdf:type owl:ObjectProperty ;
                        rdfs:domain :EnergyCertificate ;
                        rdfs:range :UserRecommendations ;
                        rdfs:comment "Documento de recomendaciones de uso entregado al usuario/arrendatario del edificio (Art. 8.1.f)."@es ,
                                     "User recommendations document delivered to the building user/tenant (Art. 8.1.f)."@en ;
                        rdfs:label "has user recommendations"@en ,
                                   "tiene recomendaciones de uso"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/heatingConsumption
:heatingConsumption rdf:type owl:ObjectProperty ;
                    rdfs:domain :EnergyRating ;
                    rdfs:range <http://qudt.org/schema/qudt/QuantityValue> ;
                    rdfs:comment "Consumo de calefacción. Se expresa como qudt:QuantityValue, típicamente en kWh/m²·año."@es ,
                                 "Heating consumption. Expressed as qudt:QuantityValue, typically in kWh/m²·year."@en ;
                    rdfs:label "consumo de calefacción"@es ,
                               "heating consumption"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/heatingDemand
:heatingDemand rdf:type owl:ObjectProperty ;
               rdfs:domain :EnergyRating ;
               rdfs:range <http://qudt.org/schema/qudt/QuantityValue> ;
               rdfs:comment "Demanda de calefacción. Se expresa como qudt:QuantityValue, típicamente en kWh/m²·año."@es ,
                            "Heating demand. Expressed as qudt:QuantityValue, typically in kWh/m²·year."@en ;
               rdfs:label "demanda de calefacción"@es ,
                          "heating demand"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/heatingEfficiency
:heatingEfficiency rdf:type owl:ObjectProperty ;
                   rdfs:domain :EnergyCertificate ;
                   rdfs:range <http://qudt.org/schema/qudt/QuantityValue> ;
                   rdfs:comment "Rendimiento estacional del sistema de calefacción. Se expresa como qudt:QuantityValue."@es ,
                                "Seasonal efficiency of the heating system. Expressed as qudt:QuantityValue."@en ;
                   rdfs:label "rendimiento estacional calefacción"@es ,
                              "seasonal heating efficiency"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/heatingEnergySource
:heatingEnergySource rdf:type owl:ObjectProperty ;
                     rdfs:domain :EnergyCertificate ;
                     rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                         owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/EnergySource>
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                     rdfs:comment "Energy source of the heating system according to the energy-source controlled vocabulary."@en ,
                                  "Fuente de energía del sistema de calefacción según el vocabulario controlado de fuentes de energía."@es ;
                     rdfs:label "fuente energética de calefacción"@es ,
                                "heating energy source"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/improvedRatingLetter
:improvedRatingLetter rdf:type owl:ObjectProperty ;
                      rdfs:domain :ImprovementRecommendation ;
                      rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                          owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/RatingLetter>
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
                      rdfs:comment "Estimated energy rating letter after implementation of the recommendation, according to the rating-letter controlled vocabulary."@en ,
                                   "Letra de calificación energética estimada tras la implementación de la recomendación, según el vocabulario controlado de letras de calificación."@es ;
                      rdfs:label "calificación estimada tras mejora"@es ,
                                 "improved rating letter"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/issuedBy
:issuedBy rdf:type owl:ObjectProperty ;
          owl:inverseOf :issuedCertificate ;
          rdfs:domain :EnergyCertificate ;
          rdfs:range :CompetentTechnician ;
          rdfs:comment "Competent technician who signs the certificate."@en ,
                       "Técnico competente que suscribe el certificado."@es ;
          rdfs:label "emitido por"@es ,
                     "issued by"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/issuedCertificate
:issuedCertificate rdf:type owl:ObjectProperty ;
                   rdfs:domain :CompetentTechnician ;
                   rdfs:range :EnergyCertificate ;
                   rdfs:comment "Certificado emitido por este técnico."@es ,
                                "Certificate issued by this technician."@en ;
                   rdfs:label "certificado emitido"@es ,
                              "issued certificate"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/labelFor
:labelFor rdf:type owl:ObjectProperty ;
          rdfs:domain :EnergyLabel ;
          rdfs:range :EnergyCertificate ;
          rdfs:comment "Certificado al que corresponde esta etiqueta."@es ,
                       "Certificate this label belongs to."@en ;
          rdfs:label "etiqueta para"@es ,
                     "label for"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/labelRatingLetter
:labelRatingLetter rdf:type owl:ObjectProperty ;
                   rdfs:domain :EnergyLabel ;
                   rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                     [ rdf:type owl:Restriction ;
