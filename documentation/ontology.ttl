#################################################################
#    Classes
#################################################################

###  http://qudt.org/schema/qudt/QuantityValue
<http://qudt.org/schema/qudt/QuantityValue> rdf:type owl:Class ;
                                            rdfs:comment "Numeric value with explicit unit of measure (qudt:numericValue + qudt:hasUnit). Allows representing physical quantities such as energy (kWh/m²·year), emissions (kgCO2/m²·year), power (kW), area (m²), percentage, etc."@en ,
                                                         "Valor numérico con unidad de medida explícita (qudt:numericValue + qudt:hasUnit). Permite representar magnitudes físicas como energía (kWh/m²·año), emisiones (kgCO2/m²·año), potencia (kW), superficie (m²), porcentaje, etc."@es ;
                                            rdfs:isDefinedBy <http://qudt.org/schema/qudt/> ;
                                            rdfs:label "Quantity value"@en ,
                                                       "Valor de cantidad"@es .


