@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix cc:       <http://creativecommons.org/ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix edintceekos-rl: <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/rating-letter/> .

# ---------------------------------------------------------------------------
# CONCEPT SCHEME
# ---------------------------------------------------------------------------
edintceekos-rl:RatingLetters a skos:ConceptScheme ;
    dcterms:issued "2026-05-25"^^xsd:date ;
    dcterms:modified "2026-05-25"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of SKOS thesauri used by the Energy Performance Certificate ontology."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por la ontología de Certificados de Eficiencia Energética."@es ;
    rdfs:label "Rating letters"@en ;
    rdfs:label "Letras de calificación"@es ;
    dcterms:title "Esquema de conceptos agrupando las letras de la escala de calificación energética A-G"@es ;
    dcterms:title "Concept scheme grouping the energy rating scale letters A-G"@en ;
    skos:note "Vocabulario de letras de calificación derivado del RD 390/2021, Art. 2.a."@es ;
    skos:note "Vocabulary of rating letters derived from RD 390/2021, Art. 2.a."@en .

# ---------------------------------------------------------------------------
# A — Most efficient
# ---------------------------------------------------------------------------
edintceekos-rl:A a skos:Concept ;
    skos:inScheme edintceekos-rl:RatingLetters ;
    skos:prefLabel "A"@es ;
    skos:prefLabel "A"@en ;
    skos:notation "A" ;
    skos:definition "Edificio de eficiencia energética más alta en la escala A-G."@es ;
    skos:definition "Building with the highest energy efficiency on the A-G scale."@en .

