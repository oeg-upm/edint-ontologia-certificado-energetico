# C
# ---------------------------------------------------------------------------
edintceekos-rl:C a skos:Concept ;
    skos:inScheme edintceekos-rl:RatingLetters ;
    skos:prefLabel "C"@es ;
    skos:prefLabel "C"@en ;
    skos:notation "C" .

# ---------------------------------------------------------------------------
