@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix cc:       <http://creativecommons.org/ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix edintceekos-pt: <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/procedure-type/> .

# ---------------------------------------------------------------------------
# CONCEPT SCHEME
# ---------------------------------------------------------------------------
edintceekos-pt:ProcedureTypes a skos:ConceptScheme ;
    dcterms:issued "2026-05-25"^^xsd:date ;
    dcterms:modified "2026-05-25"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of SKOS thesauri used by the Energy Performance Certificate ontology."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por la ontología de Certificados de Eficiencia Energética."@es ;
    rdfs:label "Procedure types"@en ;
    rdfs:label "Tipos de procedimiento"@es ;
    dcterms:title "Esquema de conceptos agrupando los tipos de procedimiento de cálculo reconocido"@es ;
    dcterms:title "Concept scheme grouping recognised calculation procedure types"@en ;
    skos:note "Vocabulario de tipos de procedimiento derivado del RD 390/2021, Art. 4.2.a y Art. 5."@es ;
    skos:note "Vocabulary of procedure types derived from RD 390/2021, Art. 4.2.a and Art. 5."@en .

# ---------------------------------------------------------------------------
# GENERAL — Procedimiento general
# ---------------------------------------------------------------------------
edintceekos-pt:General a skos:Concept ;
    skos:inScheme edintceekos-pt:ProcedureTypes ;
    skos:prefLabel "General"@es ;
    skos:prefLabel "General"@en ;
    skos:notation "general" ;
    skos:definition "Procedimiento general de cálculo de la calificación energética, aplicable a cualquier tipo de edificio."@es ;
    skos:definition "General procedure for calculating the energy rating, applicable to any building type."@en .

# ---------------------------------------------------------------------------
# SIMPLIFIED — Procedimiento simplificado
# ---------------------------------------------------------------------------
edintceekos-pt:Simplified a skos:Concept ;
    skos:inScheme edintceekos-pt:ProcedureTypes ;
    skos:prefLabel "Simplificado"@es ;
    skos:prefLabel "Simplified"@en ;
    skos:notation "simplified" ;
    skos:definition "Procedimiento simplificado de cálculo, aplicable a determinados tipos de edificio según los criterios del RD 390/2021."@es ;
    skos:definition "Simplified calculation procedure, applicable to certain building types according to RD 390/2021 criteria."@en .
