@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix cc:       <http://creativecommons.org/ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix edintceekos-db: <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/data-basis/> .

# ---------------------------------------------------------------------------
# CONCEPT SCHEME
# ---------------------------------------------------------------------------
edintceekos-db:DataBasisTypes a skos:ConceptScheme ;
    dcterms:issued "2026-05-25"^^xsd:date ;
    dcterms:modified "2026-05-25"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of SKOS thesauri used by the Energy Performance Certificate ontology."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por la ontología de Certificados de Eficiencia Energética."@es ;
    rdfs:label "Data basis types"@en ;
    rdfs:label "Tipos de base de datos"@es ;
    dcterms:title "Esquema de conceptos agrupando los tipos de base de los indicadores de calificación energética"@es ;
    dcterms:title "Concept scheme grouping the data-basis types for energy rating indicators"@en ;
    skos:note "Vocabulario de tipos de base de datos derivado del RD 390/2021, Art. 6.7."@es ;
    skos:note "Vocabulary of data-basis types derived from RD 390/2021, Art. 6.7."@en .

# ---------------------------------------------------------------------------
# MEASURED — Datos medidos
# ---------------------------------------------------------------------------
edintceekos-db:Measured a skos:Concept ;
    skos:inScheme edintceekos-db:DataBasisTypes ;
    skos:prefLabel "Medidos"@es ;
    skos:prefLabel "Measured"@en ;
    skos:notation "measured" ;
    skos:definition "Indicadores obtenidos a partir de datos de consumo medidos real del edificio."@es ;
    skos:definition "Indicators obtained from measured real consumption data of the building."@en .

# ---------------------------------------------------------------------------
# CALCULATED — Datos calculados
# ---------------------------------------------------------------------------
edintceekos-db:Calculated a skos:Concept ;
    skos:inScheme edintceekos-db:DataBasisTypes ;
    skos:prefLabel "Calculados"@es ;
    skos:prefLabel "Calculated"@en ;
    skos:notation "calculated" ;
    skos:definition "Indicadores obtenidos mediante cálculo con el procedimiento reconocido."@es ;
    skos:definition "Indicators obtained by calculation with the recognised procedure."@en .

# ---------------------------------------------------------------------------
# MIXED — Datos mixtos
# ---------------------------------------------------------------------------
edintceekos-db:Mixed a skos:Concept ;
    skos:inScheme edintceekos-db:DataBasisTypes ;
    skos:prefLabel "Mixtos"@es ;
    skos:prefLabel "Mixed"@en ;
    skos:notation "mixed" ;
    skos:definition "Indicadores obtenidos a partir de una combinación de datos medidos y calculados."@es ;
    skos:definition "Indicators obtained from a combination of measured and calculated data."@en .
